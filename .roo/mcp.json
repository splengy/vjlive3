{
	"mcpServers": {
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"/home/happy/Desktop/claude projects"
			],
			"alwaysAllow": [
				"read_multiple_files",
				"read_text_file",
				"list_directory",
				"create_directory",
				"edit_file"
			]
		},
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"DEFAULT_MINIMUM_TOKENS": ""
			}
		},
		"puppeteer": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-puppeteer"
			]
		},
		"time": {
			"command": "uvx",
			"args": [
				"mcp-server-time"
			]
		},
		"memory": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-memory"
			]
		},
		"augment-context-engine": {
			"command": "auggie",
			"args": [
				"--mcp",
				"--mcp-auto-workspace"
			]
		},
		"vjlive-switchboard": {
			"command": "python",
			"args": [
				"mcp_client.py"
			],
			"env": {
				"SSE_URL": "http://localhost:8000/sse"
			}
		}
	}
}