---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VJLive Software - 0.0–10.0 Signal Standard</title>
  <link rel="stylesheet" href="/src/styles/global.css">
</head>
<body class="vj-black text-white min-h-screen">
  <Header title="VJLive Software" />
  
  <main>
    <!-- Hero Section -->
    <section class="py-20 px-6 relative overflow-hidden">
      <div class="absolute inset-0 scanlines opacity-5 pointer-events-none"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-vj-green/10 blur-[160px] rounded-full pointer-events-none"></div>
      <div class="container mx-auto text-center relative z-10">
        <h1 class="text-5xl font-bold mb-6 neon-glow">VJLive Software</h1>
        <p class="text-xl text-vj-green mb-8">The 0.0–10.0 VJLive Signal Standard</p>
        <p class="text-lg text-vj-secondary max-w-3xl mx-auto">
          Converting analog hardware logic into visual shaders through a revolutionary digital signal processing framework
        </p>
      </div>
    </section>

    <!-- Signal Standard Section -->
    <section class="py-20 px-6">
      <div class="container mx-auto">
        <h2 class="text-4xl font-bold text-center mb-16 text-vj-green">Signal Standard Architecture</h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h3 class="text-2xl font-bold mb-6">0.0–10.0 VJLive Signal Standard</h3>
            <p class="text-vj-secondary mb-6">
              The VJLive signal standard represents a paradigm shift in visual synthesis, translating analog hardware logic into digital shader processing through a precise 0.0–10.0 voltage range.
            </p>
            <p class="text-vj-secondary mb-6">
              Each value in this range corresponds to specific visual parameters, enabling seamless cross-module compatibility and predictable behavior across the entire VJLive ecosystem.
            </p>
            
            <!-- Signal Visualization -->
            <div class="bg-vj-dark/50 p-6 rounded-lg border border-vj-green/30">
              <h4 class="text-lg font-semibold mb-4 text-vj-green">Signal Mapping</h4>
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <span class="text-vj-secondary">0.0</span>
                  <span class="text-sm">Silence/Off</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-vj-secondary">2.5</span>
                  <span class="text-sm">Low Activity</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-vj-secondary">5.0</span>
                  <span class="text-sm">Base Level</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-vj-secondary">7.5</span>
                  <span class="text-sm">High Activity</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-vj-secondary">10.0</span>
                  <span class="text-sm">Maximum</span>
                </div>
              </div>
            </div>
          </div>
          
    <!-- Technical Deep Dives -->
    <section class="py-20 px-6 bg-white/[0.02]">
      <div class="container mx-auto">
        <h2 class="text-4xl font-black text-center mb-16 neon-glow uppercase tracking-widest">Technical Deep Dives</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Unified Matrix -->
          <a href="/software/matrix-system" class="glass-panel p-8 rounded-xl border border-white/5 hover:border-vj-green/50 transition-all group block">
            <div class="text-vj-green mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-4 uppercase text-white">Unified Matrix</h3>
            <p class="text-vj-secondary text-xs mb-6 leading-relaxed">
              The neural backbone of VJLive. Intelligent signal routing with 0.0–10.0 voltage emulation and conflict resolution.
            </p>
            <span class="text-[10px] font-mono text-vj-green uppercase tracking-[0.2em] group-hover:neon-glow-green transition-all">Enter Matrix Ω >></span>
          </a>

          <!-- Mood Manifold -->
          <a href="/software/mood-manifold" class="glass-panel p-8 rounded-xl border border-white/5 hover:border-vj-purple/50 transition-all group block">
            <div class="text-vj-purple mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-4 uppercase text-white">Mood Manifold</h3>
            <p class="text-vj-secondary text-xs mb-6 leading-relaxed">
              Exotic modulation space using Chaos Theory, Fractal Dimensions, and Quantum Superposition for organic evolution.
            </p>
            <span class="text-[10px] font-mono text-vj-purple uppercase tracking-[0.2em] group-hover:neon-glow-purple transition-all">Analyze Manifold >></span>
          </a>

          <!-- Modular Effects -->
          <a href="/software/modular-effects" class="glass-panel p-8 rounded-xl border border-white/5 hover:border-vj-pink/50 transition-all group block">
            <div class="text-vj-pink mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86 1.417l-1.135 1.135a2 2 0 01-1.414.586H10a2 2 0 01-1.414-.586l-1.135-1.135a6 6 0 00-3.86-1.417l-2.387.477a2 2 0 00-1.022.547l-.34.34a2 2 0 000 2.828l1.34 1.34a2 2 0 002.828 0l.34-.34a2 2 0 00.547-1.022l.477-2.387a6 6 0 00-1.417-3.86l-1.135-1.135a2 2 0 01-.586-1.414V10a2 2 0 01.586-1.414l1.135-1.135a6 6 0 001.417-3.86l-.477-2.387a2 2 0 00-.547-1.022l-.34-.34a2 2 0 00-2.828 0l-1.34 1.34a2 2 0 000 2.828l.34.34a2 2 0 001.022.547l2.387.477a6 6 0 003.86-1.417l1.135-1.135a2 2 0 011.414-.586h.01a2 2 0 011.414.586l1.135 1.135a6 6 0 003.86 1.417l2.387-.477a2 2 0 001.022-.547l.34-.34a2 2 0 000-2.828l-1.34-1.34a2 2 0 00-2.828 0l-.34.34z"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-4 uppercase text-white">Modular Effects</h3>
            <p class="text-vj-secondary text-xs mb-6 leading-relaxed">
              Directed Acyclic Graph (DAG) processing model with infinite nesting and pin-based modulation logic.
            </p>
            <span class="text-[10px] font-mono text-vj-pink uppercase tracking-[0.2em] group-hover:shadow-[0_0_10px_rgba(255,105,180,0.5)] transition-all">Patch Logic >></span>
          </a>

          <!-- Timeline -->
          <a href="/software/timeline" class="glass-panel p-8 rounded-xl border border-white/5 hover:border-vj-green/50 transition-all group block">
            <div class="text-vj-green mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-4 uppercase text-white">Deck Controls</h3>
            <p class="text-vj-secondary text-xs mb-6 leading-relaxed">
              Predictive 4K media pre-loading and micro-quantized BPM sequencing for high-stakes live performance.
            </p>
            <span class="text-[10px] font-mono text-vj-green uppercase tracking-[0.2em] group-hover:neon-glow-green transition-all">Master Sync >></span>
          </a>
        </div>
      </div>
    </section>
        </div>
      </div>
    </section>

    <!-- Audio Intelligence Section -->
    <section class="py-20 px-6 bg-vj-dark/30 border-y border-vj-green/10">
      <div class="container mx-auto">
        <h2 class="text-4xl font-bold text-center mb-16 text-vj-green uppercase tracking-widest">Audio Intelligence</h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1">
            <div class="glass-panel p-8 rounded-xl border border-vj-green/20">
              <h3 class="text-2xl font-bold mb-6 text-white">Semantic Intent Engine</h3>
              <p class="text-vj-secondary mb-6">
                Beyond traditional FFT, VJLive utilizes a sophisticated **Semantic Intent Layer** that translates natural language descriptors into real-time parameter biases.
              </p>
              <div class="space-y-4">
                <div class="flex items-start gap-4 p-4 rounded bg-white/[0.02] border border-white/5">
                  <div class="text-vj-green font-mono text-sm mt-1">INTENT:</div>
                  <div>
                    <div class="text-white font-bold text-sm mb-1 uppercase">Energy & Intensity</div>
                    <p class="text-xs text-vj-secondary italic">"Make it look aggressive but organic"</p>
                  </div>
                </div>
                <div class="flex items-start gap-4 p-4 rounded bg-white/[0.02] border border-white/5">
                  <div class="text-vj-purple font-mono text-sm mt-1">INTENT:</div>
                  <div>
                    <div class="text-white font-bold text-sm mb-1 uppercase">Frequency Focus</div>
                    <p class="text-xs text-vj-secondary italic">"Calm ocean feel with bass-driven glitch"</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <h3 class="text-2xl font-bold mb-6">NLP-Driven Visual Biasing</h3>
            <p class="text-vj-secondary mb-6">
              Our system analyzes descriptive commands to shift the weight of audio features. An "aggressive" intent will automatically scale the sensitivity of the Bass/Beat features while introducing offset biases to distortion and datamosh parameters.
            </p>
            <ul class="space-y-4 text-sm font-mono text-vj-green/80">
              <li class="flex gap-3">
                <span class="text-vj-green">▷</span>
                <span>Dynamic Sensitivity Scaling</span>
              </li>
              <li class="flex gap-3">
                <span class="text-vj-green">▷</span>
                <span>Priority-Based Bias Hierarchy</span>
              </li>
              <li class="flex gap-3">
                <span class="text-vj-green">▷</span>
                <span>Context-Aware Feature Mapping</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Exotic Modulation Section -->
    <section class="py-20 px-6">
      <div class="container mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
          <h2 class="text-4xl font-bold text-vj-purple uppercase tracking-widest">Exotic Modulation</h2>
          <a href="/software/mood-manifold" class="px-8 py-3 border border-vj-purple/30 text-vj-purple font-mono text-sm uppercase tracking-widest hover:bg-vj-purple hover:text-white transition-all">Deep Dive: Mood Manifold</a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Chaos Theory -->
          <div class="glass-panel p-8 rounded-xl border-t-2 border-vj-pink hover:bg-white/5 transition-all">
            <h4 class="text-vj-pink font-mono text-xs mb-2">MODE: LOGISTIC_MAP</h4>
            <h3 class="text-xl font-bold mb-4">Chaos Theory</h3>
            <p class="text-sm text-vj-secondary mb-6">Utilizes non-linear strange attractors to generate unpredictable but coherent parameter movement, emulating natural entropy.</p>
            <div class="h-1 bg-vj-pink/20 rounded overflow-hidden">
              <div class="h-full bg-vj-pink w-2/3 animate-pulse"></div>
            </div>
          </div>

          <!-- Fractal Dimension -->
          <div class="glass-panel p-8 rounded-xl border-t-2 border-vj-purple hover:bg-white/5 transition-all">
            <h4 class="text-vj-purple font-mono text-xs mb-2">MODE: SELF_SIMILAR</h4>
            <h3 class="text-xl font-bold mb-4">Fractal Dimension</h3>
            <p class="text-sm text-vj-secondary mb-6">Interpolates across multi-scale self-similarity patterns, creating geometric complexity that evolves recursively within the manifold.</p>
            <div class="h-1 bg-vj-purple/20 rounded overflow-hidden">
              <div class="h-full bg-vj-purple w-1/2 animate-pulse"></div>
            </div>
          </div>

          <!-- Quantum Superposition -->
          <div class="glass-panel p-8 rounded-xl border-t-2 border-vj-green hover:bg-white/5 transition-all">
            <h4 class="text-vj-green font-mono text-xs mb-2">MODE: WAVE_INTERFERENCE</h4>
            <h3 class="text-xl font-bold mb-4">Quantum State</h3>
            <p class="text-sm text-vj-secondary mb-6">Treats mood anchors as complex probability amplitudes, producing visual interference patterns through wave-function collapse logic.</p>
            <div class="h-1 bg-vj-green/20 rounded overflow-hidden">
              <div class="h-full bg-vj-green w-3/4 animate-pulse"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- System Architecture Tiers -->
    <section class="py-20 px-6 bg-vj-dark/50 border-t border-white/5">
      <div class="container mx-auto">
        <h2 class="text-4xl font-black text-center mb-16 neon-glow uppercase tracking-widest">Deployment Architectures</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
          <div class="glass-panel p-6 border-t-2 border-vj-green bg-white/[0.02] text-center">
            <h4 class="text-[10px] font-mono text-vj-green mb-2">TIER 1</h4>
            <h3 class="font-bold mb-2">Desktop Dev</h3>
            <p class="text-[10px] text-vj-secondary uppercase tracking-tighter">x86_64 Prototyping</p>
          </div>
          <div class="glass-panel p-6 border-t-2 border-vj-purple bg-white/[0.02] text-center">
            <h4 class="text-[10px] font-mono text-vj-purple mb-2">TIER 2</h4>
            <h3 class="font-bold mb-2">Containerized</h3>
            <p class="text-[10px] text-vj-secondary uppercase tracking-tighter">Docker Pipelines</p>
          </div>
          <div class="glass-panel p-6 border-t-2 border-vj-pink bg-white/[0.02] text-center">
            <h4 class="text-[10px] font-mono text-vj-pink mb-2">TIER 3</h4>
            <h3 class="font-bold mb-2">Native HW</h3>
            <p class="text-[10px] text-vj-secondary uppercase tracking-tighter">Bare-Metal Performance</p>
          </div>
          <div class="glass-panel p-6 border-t-2 border-vj-green bg-white/[0.02] text-center">
            <h4 class="text-[10px] font-mono text-vj-green mb-2">TIER 4</h4>
            <h3 class="font-bold mb-2">Agentic</h3>
            <p class="text-[10px] text-vj-secondary uppercase tracking-tighter">LLM / RAG Assisted</p>
          </div>
          <div class="glass-panel p-6 border-t-2 border-vj-purple bg-white/[0.02] text-center">
            <h4 class="text-[10px] font-mono text-vj-purple mb-2">TIER 5</h4>
            <h3 class="font-bold mb-2">Cluster</h3>
            <p class="text-[10px] text-vj-secondary uppercase tracking-tighter">Multi-Node Sync</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Infrastructure -->
    <section class="py-20 px-6 border-t border-white/5">
      <div class="container mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
          <h2 class="text-4xl font-bold text-vj-green uppercase tracking-widest">Core Infrastructure</h2>
          <a href="/software/matrix-system" class="px-8 py-3 border border-vj-green/30 text-vj-green font-mono text-sm uppercase tracking-widest hover:bg-vj-green hover:text-white transition-all">Deep Dive: Routing Matrix</a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center group">
            <div class="w-16 h-16 bg-vj-green/20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-vj-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">Real-time Shaders</h3>
            <p class="text-vj-secondary text-sm">Low-latency GPU compilation for zero-frame delay visual synthesis.</p>
          </div>

          <div class="text-center group">
            <div class="w-16 h-16 bg-vj-purple/20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-vj-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">Hardware HAL</h3>
            <p class="text-vj-secondary text-sm">Abstraction layer for seamless migration between ARM64 and x86 architectures.</p>
          </div>

          <div class="text-center group">
            <div class="w-16 h-16 bg-vj-green/20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-vj-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">Cluster Sync</h3>
            <p class="text-vj-secondary text-sm">Deterministic frame-sync for distributed multi-node rendering ecosystems.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</body>
</html>