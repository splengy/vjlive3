# VJLive3 Environment Configuration
#
# Copy this file to .env and fill in the values.
# DO NOT commit the .env file - it contains secrets!
#
# To use: cp .env.example .env

# Development settings
DEBUG=True
LOG_LEVEL=INFO

# Application settings
APP_NAME="VJLive3"
ENVIRONMENT=development

# Database (if applicable)
# DATABASE_URL=sqlite:///./vjlive3.db

# API Keys (add as needed)
# API_KEY=your_api_key_here
# OPENAI_API_KEY=your_openai_key_here

# Network settings
# HOST=127.0.0.1
# PORT=8000

# Security
# SECRET_KEY=generate_a_random_secret_key_here
# JWT_SECRET=generate_another_random_secret

# External services
# NDI_SDK_PATH=/path/to/ndi/sdk
# GITHUB_TOKEN=your_github_token

# Performance
# GPU_ENABLED=True
# MAX_FPS=60

# Logging
# LOG_FILE=logs/vjlive3.log
# LOG_MAX_SIZE=10MB
# LOG_BACKUP_COUNT=5