import os
import re
import ast
from pathlib import Path
import time

def sanitize_filename(name: str) -> str:
    name = re.sub(r'[^\w\-_\.]', '_', name)
    name = re.sub(r'_+', '_', name)
    return name.strip('_').lower()

def build_legacy_catalog(legacy_dirs):
    catalog = {}
    for ldir, source_name in legacy_dirs:
        for py_file in Path(ldir).rglob("*.py"):
            try:
                content = py_file.read_text(encoding='utf-8', errors='ignore')
                tree = ast.parse(content)
                for node in ast.walk(tree):
                    if isinstance(node, ast.ClassDef):
                        class_name = node.name
                        
                        methods = [m.name for m in node.body if isinstance(m, ast.FunctionDef)]
                        
                        params = []
                        for m in node.body:
                            if isinstance(m, ast.FunctionDef) and m.name == '__init__':
                                params = [a.arg for a in m.args.args if a.arg != 'self']
                                break
                                
                        catalog[class_name.lower()] = {  # Store as lowercase for fuzzy matching
                            "source": source_name,
                            "filepath": str(py_file),
                            "class_name": class_name,
                            "methods": methods,
                            "params": params
                        }
            except Exception:
                pass
    return catalog

def fuzzy_match(desc: str, class_target: str, base_name: str, catalog: dict):
    # Try exact matches first (lowercased)
    if class_target.lower() in catalog:
        return catalog[class_target.lower()]
    if base_name.lower() in catalog:
        return catalog[base_name.lower()]
        
    # Heuristic for Befaco/Bogaudio
    # e.g., "BF: EvenVCO (vbf_evenvco)" -> "EvenVCO" -> "vevenvco"
    clean_base = re.sub(r'^(BF|BG|V):\s*', '', base_name)
    clean_base_no_space = clean_base.replace(" ", "").lower()
    
    # Try with 'v' prefix
    v_prefixed = "v" + clean_base_no_space
    if v_prefixed in catalog:
        return catalog[v_prefixed]
        
    # Try without prefix
    if clean_base_no_space in catalog:
        return catalog[clean_base_no_space]
        
    # P4-BA or P4-BF specific (e.g. "B1to8")
    if clean_base_no_space.startswith("b"):
        # "B1to8" -> "vb1to8"
        p4_attempt = "v" + clean_base_no_space
        if p4_attempt in catalog:
            return catalog[p4_attempt]
            
    # Try matching just the first huge chunk if there's symbols
    alpha_only = re.sub(r'[^a-z]', '', clean_base_no_space)
    v_alpha = "v" + alpha_only
    if v_alpha in catalog:
        return catalog[v_alpha]
        
    return None

def create_rich_spec(task_id: str, desc: str, specs_dir: Path, template_content: str, catalog: dict):
    # Ignore P0 and P6 non-code tasks
    if task_id.startswith("P0-") or task_id.startswith("P6-"):
        return False, "Ignored Meta Task"

    class_target = ""
    match = re.search(r'^(.*?)(?:\s*\((.*?)\))?$', desc)
    if match:
        base_name = match.group(1).strip()
        class_target = match.group(2).strip() if match.group(2) else ""
    else:
        base_name = desc.strip()
        
    safe_name = sanitize_filename(base_name)
    if not safe_name:
        safe_name = "unknown_module"
        
    if list(specs_dir.glob(f"{task_id}_*.md")):
        return False, "Already exists"
        
    filename = f"{task_id}_{safe_name}.md"
    filepath = specs_dir / filename
    
    rich_info = fuzzy_match(desc, class_target, base_name, catalog)
    if not rich_info:
        return False, f"Fuzzy match failed for {class_target or base_name}"

    module_name = desc
    phase_match = re.search(r'^(P\d+)', task_id)
    phase = phase_match.group(1) if phase_match else "Unknown Phase"
    
    content = template_content
    content = content.replace("[TASK-ID]", task_id)
    content = content.replace("[Module Name]", module_name)
    content = content.replace("[e.g. Phase 2 / P2-H3]", f"{phase} / {task_id}")
    content = content.replace("[Agent name]", "Antigravity")
    content = content.replace("[YYYY-MM-DD]", time.strftime("%Y-%m-%d"))
    
    injection = "\n## Legacy References\n"
    injection += f"- **Source Codebase**: `{rich_info['source']}`\n"
    injection += f"- **File Paths**: `{rich_info['filepath']}`\n"
    injection += f"- **Class Names**: `{rich_info['class_name']}`\n"
    
    methods_str = ", ".join(rich_info['methods'][:10])
    if len(rich_info['methods']) > 10: methods_str += "..."
    if not methods_str: methods_str = "None found"
    injection += f"- **Key Algorithms (Methods)**: `{methods_str}`\n"
    
    params_str = ", ".join(rich_info['params'])
    if not params_str: params_str = "None found"
    injection += f"- **Parameter Mappings (__init__ args)**: `{params_str}`\n"
    
    injection += "- **Edge Cases**: Needs review of implementation for tight coupling or hardware dependencies.\n\n"
    
    footer_idx = content.find("---")
    if "END OF SPECIFICATION" in content:
        footer_idx = content.rfind("---", 0, content.rfind("END OF SPECIFICATION"))
        
    if footer_idx != -1:
         content = content[:footer_idx] + injection + content[footer_idx:]
    else:
        content += injection
        
    filepath.write_text(content, encoding='utf-8')
    return True, "Success"

def main():
    root = Path("/home/happy/Desktop/claude projects/VJLive3_The_Reckoning")
    board_path = root / "BOARD.md"
    specs_dir = root / "docs/specs"
    template_path = specs_dir / "_TEMPLATE.md"
    
    legacy_dirs = [
        ("/home/happy/Desktop/claude projects/vjlive", "vjlive"),
        ("/home/happy/Desktop/claude projects/VJlive-2", "VJlive-2")
    ]
    
    print("Building fuzzy catalog...")
    catalog = build_legacy_catalog(legacy_dirs)
    
    with open(board_path, 'r', encoding='utf-8') as f:
        board_content = f.read()
        
    template_content = template_path.read_text(encoding='utf-8')

    tasks = []
    for line in board_content.split('\n'):
        match = re.search(r'\|\s*(P[0-9]+-[A-Z0-9]+)\s*\|\s*(.*?)\s*\|', line)
        if match:
            task_id = match.group(1).strip()
            desc = match.group(2).strip()
            tasks.append((task_id, desc))
            
    tasks.reverse()
    
    generated = 0
    failed = []
    
    print("Generating rich specs using fuzzy match backwards...")
    
    for task_id, desc in tasks:
        if "✅" in desc or "Done" in desc:
            continue
            
        success, reason = create_rich_spec(task_id, desc, specs_dir, template_content, catalog)
        if success:
            generated += 1
        elif reason.startswith("Fuzzy match failed"):
            failed.append((task_id, desc))
            
    print(f"\nGenerated {generated} specs via fuzzy mapping.")
    print(f"Still failed to match {len(failed)} tasks.")
    for f in failed:
        print(f"  {f[0]}: {f[1]}")

if __name__ == "__main__":
    main()
