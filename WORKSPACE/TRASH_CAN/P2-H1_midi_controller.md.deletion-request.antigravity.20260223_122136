## Public Interface

### MIDIController Class

```python
# src/vjlive3/input/midi_controller.py
class MIDIController:
    def __init__(self):
        """Initialize MIDI controller system"""
    
    def enumerate_devices(self) -> List[MIDIDeviceInfo]:
        """Get list of available MIDI devices"""
    
    def connect(self, device_id: str) -> None
    def disconnect(self, device_id: str) -> None
    def is_connected(self, device_id: str) -> bool
    
    def add_mapping(
        self,
        midi_type: str,  # "note_on", "control_change", etc.
        channel: int,
        number: int,
        target: str,     # "effect.scale", "dmx.channel.1", etc.
        parameter: str,
        mode: MappingMode = MappingMode.ABSOLUTE,
        min_value: float = 0.0,
        max_value: float = 1.0
    ) -> None
    
    def remove_mapping(self, mapping_id: str) -> None
    def get_mappings(self) -> List[MIDIMapping]
    
    def start_learning(self, target: str, parameter: str) -> LearningSession
    def cancel_learning(self, session_id: str) -> None
    
    def send_feedback(
        self,
        device_id: str,
        message: MIDIMessage  # Note, CC, etc.
    ) -> None
    
    def save_preset(self, name: str, filepath: str) -> None
    def load_preset(self, filepath: str) -> None
```

### MIDIMapping Data Structure

```python
@dataclass
class MIDIMapping:
    id: str
    device_id: str
    midi_type: str
    channel: int
    number: int
    target: str
    parameter: str
    mode: MappingMode
    min_value: float
    max_value: float
    enabled: bool = True

class MappingMode(Enum):
    ABSOLUTE = "absolute"     # 0-127 → min-max
    RELATIVE = "relative"     # Incremental changes
    TOGGLE = "toggle"         # On/off toggle
    TRIGGER = "trigger"       # Momentary trigger
```

