## Public Interface

### ProjectionMapper Class

```python
# src/vjlive3/projection/mapper.py
class ProjectionMapper:
    def __init__(self, renderer: Renderer):
        """
        Initialize projection mapping system.
        
        Args:
            renderer: Rendering engine for output
        """
    
    def create_output(
        self,
        output_id: str,
        display_index: int,
        resolution: Tuple[int, int],
        warp_type: WarpType = WarpType.PERSPECTIVE
    ) -> Output:
        """Create new output with warping"""
    
    def set_warp(
        self,
        output_id: str,
        warp_params: WarpParameters
    ) -> None:
        """Set warping parameters for output"""
    
    def set_edge_blend(
        self,
        output_id: str,
        blend_params: BlendParameters
    ) -> None:
        """Set edge blending parameters"""
    
    def set_mask(
        self,
        output_id: str,
        mask: Mask  # Image or geometric
    ) -> None:
        """Set masking for output"""
    
    def calibrate(
        self,
        output_id: str,
        method: CalibrationMethod,
        camera_frames: List[np.ndarray]
    ) -> CalibrationResult:
        """Run calibration procedure"""
    
    def save_calibration(self, output_id: str, filepath: str) -> None
    def load_calibration(self, output_id: str, filepath: str) -> None
    
    def render(self, output_id: str, input_texture: Texture) -> Texture:
        """Apply warping/blending/mask to input texture"""
    
    def get_statistics(self) -> ProjectionStats:
        """Get performance and status info"""
```

### WarpType Enum

```python
class WarpType(Enum):
    PERSPECTIVE = "perspective"     # 4-corner perspective
    MESH = "mesh"                   # Grid-based mesh warp
    BEZIER = "bezier"               # Bezier curve warp
    CUSTOM = "custom"               # Custom shader
```

### WarpParameters Data Structure

```python
@dataclass
class WarpParameters:
    warp_type: WarpType
    # Perspective: 4 corner points (normalized 0-1)
    corners: Optional[Tuple[Point, Point, Point, Point]] = None
    # Mesh: grid resolution and vertex positions
    mesh_resolution: Optional[Tuple[int, int]] = None
    mesh_vertices: Optional[np.ndarray] = None  # Nx2 array
    # Custom: shader parameters
    shader_params: Optional[Dict[str, float]] = None
```

### BlendParameters Data Structure

```python
@dataclass
class BlendParameters:
    enabled: bool = True
    # Blend region width (0-1)
    left_width: float = 0.1
    right_width: float = 0.1
    top_width: float = 0.0
    bottom_width: float = 0.0
    # Blend curve (gamma)
    curve: float = 2.0
    # Color correction
    brightness: float = 1.0
    contrast: float = 1.0
    saturation: float = 1.0
    # Multi-projector: overlap correction
    overlap_correction: bool = False
```

