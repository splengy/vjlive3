## 3. GLSL Fragment Shader (50 lines)

```glsl
#version 330 core
in vec2 uv;
out vec4 fragColor;

uniform sampler2D tex0;      // Current frame
uniform sampler2D texPrev;   // Previous frame
uniform float time;
uniform vec2 resolution;
uniform float u_mix;

uniform float amount;       // 0-1 blend strength
uniform float channel_mask; // 0-4: 0=all, 1=R, 2=G, 3=B, 4=luma
uniform float boost;        // 0.5-3.0 brightness multiplier
uniform float offset_x;     // -0.2 to 0.2
uniform float offset_y;     // -0.2 to 0.2
uniform float luma_mask;    // 0-1 threshold

void main() {
    vec4 a = texture(tex0, uv);
    float amt = amount;
    float cm = channel_mask;
    float bst = boost;
    vec2 off = vec2(offset_x, offset_y);
    float lm = luma_mask;

    // Sample previous frame with offset
    vec4 b = texture(texPrev, uv + off);

    // Channel mask: isolate specific channels
    vec3 b_masked = b.rgb;
    if (cm > 0.5 && cm < 1.5) b_masked *= vec3(1.0, 0.0, 0.0);  // R only
    else if (cm > 1.5 && cm < 2.5) b_masked *= vec3(0.0, 1.0, 0.0);  // G only
    else if (cm > 2.5 && cm < 3.5) b_masked *= vec3(0.0, 0.0, 1.0);  // B only
    else if (cm > 3.5) {
        float l = dot(b.rgb, vec3(0.299, 0.587, 0.114));
        b_masked = vec3(l);
    }

    // Additive blend: current + masked_previous * amount * boost
    vec3 added = a.rgb + b_masked * amt * bst;

    // Luma mask: only apply blend where current frame is bright
    if (lm > 0.01) {
        float src_luma = dot(a.rgb, vec3(0.299, 0.587, 0.114));
        float mask = smoothstep(lm * 0.5, lm, src_luma);
        added = mix(a.rgb, added, mask);
    }

    // Clamp and preserve alpha
    vec4 blended = vec4(clamp(added, 0.0, 1.0), max(a.a, b.a));

    // Final mix with original
    fragColor = mix(a, blended, u_mix);
}
```

**Line Count:** ~50 lines

**Uniforms:**
- `tex0` - current frame (bound to unit 0)
- `texPrev` - previous frame (bound to unit 1)
- `time`, `resolution`, `u_mix` - standard
- `amount`, `channel_mask`, `boost`, `offset_x`, `offset_y`, `luma_mask` - parameters

