from core.audio_reactor import AudioReactor
from core.audio_analyzer import AudioFeature
from OpenGL.GL import (glActiveTexture, glBindTexture, GL_TEXTURE0, GL_TEXTURE1, GL_TEXTURE_2D)
import logging

logger = logging.getLogger(__name__)

class BlendAddEffect(Effect):
    """Additive blend with channel masking, offset, boost."""

    def __init__(self):
        fragment_source = self._get_fragment_shader()
        super().__init__("blend_add", fragment_source)

        self.description = "Additive blending with channel mask, offset, and boost"
        self.category = "Blend"

        # Parameters (0.0-10.0)
        self.parameters = {
            'amount': 5.0,       # Blend strength (0-10 → 0-1)
            'channel_mask': 0.0, # 0=all, 3=R, 5=G, 7=B, 10=luma
            'boost': 5.0,        # Brightness multiplier (0-10 → 0.5-3.0)
            'offset_x': 5.0,     # Horizontal offset (0-10 → -0.2 to 0.2)
            'offset_y': 5.0,     # Vertical offset (0-10 → -0.2 to 0.2)
            'luma_mask': 0.0,    # Luma threshold for blending (0-10 → 0-1)
        }

        self.audio_reactor = None

    def _get_fragment_shader(self) -> str:
        """Return the 50-line GLSL shader (see spec)."""
        return """#version 330 core
        // Full shader from spec
        """

    def set_audio_analyzer(self, audio_analyzer):
        """Set audio analyzer for reactivity."""
        if audio_analyzer:
            self.audio_reactor = AudioReactor(audio_analyzer)
            self.audio_reactor.assign_audio_feature("blend_add", "amount", AudioFeature.MID, 0.0, 10.0)

    def apply_uniforms(self, time: float, resolution: tuple,
                       audio_reactor=None, semantic_layer=None):
        """Apply uniforms with audio modulation."""
        super().apply_uniforms(time, resolution, audio_reactor, semantic_layer)

        # Get modulated amount if audio reactor available
        amount = self.parameters['amount']
        if self.audio_reactor:
            amount = self.audio_reactor.get_audio_modulation("blend_add", "amount", amount)

        # Map parameters to shader ranges
        amt = amount / 10.0
        cm = self.parameters['channel_mask'] / 10.0 * 4.0  # 0-4
        bst = 0.5 + self.parameters['boost'] / 10.0 * 2.5  # 0.5-3.0
        off_x = (self.parameters['offset_x'] / 10.0 - 0.5) * 0.4
        off_y = (self.parameters['offset_y'] / 10.0 - 0.5) * 0.4
        lm = self.parameters['luma_mask'] / 10.0

        self.shader.set_uniform("amount", amt)
        self.shader.set_uniform("channel_mask", cm)
        self.shader.set_uniform("boost", bst)
        self.shader.set_uniform("offset_x", off_x)
        self.shader.set_uniform("offset_y", off_y)
        self.shader.set_uniform("luma_mask", lm)
        self.shader.set_uniform("u_mix", self.mix)

        # Bind previous frame texture
        if hasattr(self, 'prev_texture') and self.prev_texture:
            self.shader.set_uniform("texPrev", 1)

    def __del__(self):
        """Cleanup if needed."""
        try:
            if hasattr(super(), '__del__'): super().__del__()
        except: pass

def create_blend_add():
    return BlendAddEffect()
