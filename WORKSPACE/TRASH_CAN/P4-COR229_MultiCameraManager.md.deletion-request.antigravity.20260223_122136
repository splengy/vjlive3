## Implementation Notes

### Camera Source Abstraction
```python
class CameraSource(ABC):
    """Abstract base for all camera sources."""

    def __init__(self, camera_id: str, config: CameraConfig):
        self.camera_id = camera_id
        self.config = config
        self._thread: Optional[threading.Thread] = None
        self._running = False
        self._latest_frame: Optional[CameraFrame] = None
        self._frame_lock = threading.RLock()

    @abstractmethod
    def open(self) -> bool:
        """Open camera device."""
        pass

    @abstractmethod
    def close(self) -> None:
        """Close camera device."""
        pass

    @abstractmethod
    def read_frame(self) -> Optional[CameraFrame]:
        """Read a single frame from camera."""
        pass

    def start_capture(self) -> None:
        """Start continuous capture in background thread."""
        self._running = True
        self._thread = threading.Thread(target=self._capture_loop, daemon=True)
        self._thread.start()

    def stop_capture(self) -> None:
        """Stop capture thread."""
        self._running = False
        if self._thread:
            self._thread.join(timeout=2.0)

    def get_latest_frame(self) -> Optional[CameraFrame]:
        """Get the most recent frame (thread-safe)."""
        with self._frame_lock:
            return self._latest_frame

    def _capture_loop(self) -> None:
        """Background capture loop."""
        while self._running:
            try:
                frame = self.read_frame()
                if frame is not None:
                    with self._frame_lock:
                        self._latest_frame = frame
            except Exception as e:
                logger.error(f"Camera {self.camera_id} capture error: {e}")
                time.sleep(0.1)  # Avoid tight loop on error

class CameraFrame:
    """Container for a camera frame."""

    camera_id: str
    timestamp: float
    color: Optional[np.ndarray]  # RGB image
    depth: Optional[np.ndarray]  # Depth map (millimeters or normalized)
    infrared: Optional[np.ndarray]  # IR image
    point_cloud: Optional[np.ndarray]  # 3D points (X, Y, Z, RGB)
    metadata: Dict[str, Any]  # Camera metadata (exposure, gain, etc.)
```

