### Configuration Structure
```python
class CameraManagerConfig(BaseModel):
    """Multi-camera manager configuration."""

    enabled: bool = True
    auto_discovery: bool = True
    primary_camera: Optional[str] = None
    camera_profiles: Dict[str, CameraProfile] = {}
    fusion_enabled: bool = False
    fusion_method: FusionMethod = FusionMethod.WEIGHTED_AVERAGE
    frame_buffer_size: int = 3
    capture_timeout: float = 1.0  # seconds

class CameraProfile(BaseModel):
    """Camera profile configuration."""

    camera_type: CameraType
    device_path: str  # e.g., "/dev/video0", "ndi://source-name"
    resolution: Tuple[int, int]
    fps: int
    depth_range: Tuple[float, float] = (0.5, 5.0)  # min, max in meters
    exposure: Optional[int] = None
    gain: Optional[int] = None
    calibration_file: Optional[str] = None
    enabled: bool = True

class CameraType(Enum):
    DEPTH_ASTRA = "depth_astra"
    DEPTH_REALSENSE = "depth_realsense"
    RGB_USB = "rgb_usb"
    RGB_NDI = "rgb_ndi"
    RGB_IP = "rgb_ip"
    INFRARED = "infrared"
