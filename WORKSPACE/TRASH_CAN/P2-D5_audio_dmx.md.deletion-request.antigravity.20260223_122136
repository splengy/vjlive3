## Public Interface

### AudioReactiveDMX Class

```python
# src/vjlive3/dmx/audio_reactive.py
class AudioReactiveDMX:
    def __init__(
        self,
        dmx_engine: DMXEngine,
        audio_bus: AudioReactivityBus
    ):
        """
        Initialize audio-reactive DMX system.
        
        Args:
            dmx_engine: DMX engine for output
            audio_bus: Audio reactivity bus for input
        """
    
    def set_mode(self, mode: ReactivityMode) -> None:
        """Set reactivity mode (pulse, strobe, chase, wave)"""
    
    def set_mapping(
        self,
        fixture_id: str,
        audio_feature: str,  # "bass", "mid", "high", "beat", "rms"
        dmx_channel: int,
        min_value: int,
        max_value: int,
        smoothing: float = 0.1
    ) -> None:
        """Define audio-to-DMX mapping"""
    
    def enable(self) -> None
    def disable(self) -> None
    def is_enabled(self) -> bool
    
    def get_statistics(self) -> AudioReactiveStats:
        """Get performance and reactivity statistics"""
```

### ReactivityMode Enum

```python
class ReactivityMode(Enum):
    PULSE = "pulse"           # Beat-synced intensity pulse
    STROBE = "strobe"         # Fast on/off on transients
    CHASE = "chase"           # Sequential channel activation
    WAVE = "wave"             # Frequency-based color waves
    BASS_BOOST = "bass_boost" # Bass-driven intensity
    CUSTOM = "custom"         # User-defined mapping
```

### AudioReactiveStats Data Structure

```python
@dataclass
class AudioReactiveStats:
    fps: float
    audio_latency_ms: float
    dmx_update_rate: float
    active_fixtures: int
    total_mappings: int
    last_beat_time: float
    current_mode: ReactivityMode
```

