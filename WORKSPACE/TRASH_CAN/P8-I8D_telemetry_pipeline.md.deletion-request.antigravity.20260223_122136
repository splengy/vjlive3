# instrument_plugins.py
"""Add telemetry recording to all plugin process methods."""
import ast
import re

def add_telemetry_to_plugin(plugin_path: Path):
    """Inject telemetry timing into plugin.process()."""
    
    code = plugin_path.read_text()
    
    # Find process method
    pattern = r'(def process\(self, input_texture, params, context: VJLiveContext\):.*?)(return .*)'
    replacement = r'\1start = time.perf_counter()\n        \2\n        elapsed = (time.perf_counter() - start) * 1000\n        context.telemetry.record(f"plugin.{self.id}.process_time", elapsed)'
    
    code = re.sub(pattern, replacement, code, flags=re.DOTALL)
    
    plugin_path.write_text(code)
