### 5.3 Performance Tests

```python
def test_telemetry_overhead():
    """Telemetry recording should add <0.1ms per call."""
    collector = TelemetryCollector()
    context = VJLiveContext()
    context.telemetry = collector
    
    iterations = 10000
    start = time.perf_counter()
    for i in range(iterations):
        collector.record("test.metric", float(i))
    elapsed = time.perf_counter() - start
    
    per_call = elapsed / iterations * 1000
    assert per_call < 0.1, f"Telemetry overhead: {per_call}ms"

def test_snapshot_performance():
    """Snapshot generation should be fast."""
    collector = TelemetryCollector()
    
    # Populate with data
    for i in range(1000):
        collector.record("test.metric", float(i))
    
    start = time.perf_counter()
    for _ in range(100):
        snapshot = collector.snapshot()
    elapsed = time.perf_counter() - start
    
    assert elapsed / 100 < 0.001, f"Snapshot too slow: {elapsed/100}s"
