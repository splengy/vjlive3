## 3. Solution Architecture

### 3.1 TelemetryCollector Class

**Purpose**: Central hub for all metrics collection.

```python
from collections import defaultdict, deque
from typing import Dict, List, Any
import numpy as np

class TelemetryCollector:
    """Collects, aggregates, and exports telemetry data."""
    
    def __init__(self, window_size: int = 60):
        """
        Initialize collector.
        
        Args:
            window_size: Number of frames to keep in rolling window (60 = 1 second at 60Hz)
        """
        self.window_size = window_size
        
        # Raw metric storage: metric_name -> deque of values
        self.metrics: Dict[str, deque] = defaultdict(lambda: deque(maxlen=window_size))
        
        # Counters: counter_name -> int
        self.counters: Dict[str, int] = defaultdict(int)
        
        # Histograms: metric_name -> bin edges + counts
        self.histograms: Dict[str, Tuple[np.ndarray, np.ndarray]] = {}
    
    def record(self, name: str, value: float, unit: str = "ms"):
        """
        Record a metric value.
        
        Args:
            name: Metric name (e.g., "plugin.depth_blur.process_time")
            value: Numeric value
            unit: Unit of measurement (for documentation)
        """
        self.metrics[name].append(value)
        
        # Update histogram if configured
        if name in self.histograms:
            bins, counts = self.histograms[name]
            bin_idx = np.digitize(value, bins) - 1
            if 0 <= bin_idx < len(counts):
                counts[bin_idx] += 1
    
    def increment(self, name: str, amount: int = 1):
        """Increment a counter."""
        self.counters[name] += amount
    
    def snapshot(self) -> Dict[str, Any]:
        """
        Return current statistics for all metrics.
        
        Returns:
            Dict with p50, p95, p99, mean, min, max for each metric
        """
        stats = {}
        
        for name, values in self.metrics.items():
            if len(values) == 0:
                continue
            
            values_array = np.array(values)
            stats[name] = {
                "count": len(values),
                "mean": float(np.mean(values_array)),
                "min": float(np.min(values_array)),
                "max": float(np.max(values_array)),
                "p50": float(np.percentile(values_array, 50)),
                "p95": float(np.percentile(values_array, 95)),
                "p99": float(np.percentile(values_array, 99)),
                "unit": self._get_unit(name)
            }
        
        # Add counters
        for name, value in self.counters.items():
            stats[name] = {"count": value, "unit": "count"}
        
        return stats
    
    def _get_unit(self, metric_name: str) -> str:
        """Infer unit from metric name."""
        if "time" in metric_name or "ms" in metric_name:
            return "ms"
        elif "fps" in metric_name:
            return "fps"
        elif "memory" in metric_name or "mb" in metric_name:
            return "MB"
        elif "violations" in metric_name:
            return "count"
        else:
            return "unknown"
    
    def reset(self):
        """Clear all metrics (useful for testing)."""
        self.metrics.clear()
        self.counters.clear()
        self.histograms.clear()
    
    def export_prometheus(self) -> str:
        """
        Export metrics in Prometheus text format.
        
        Returns:
            String in Prometheus exposition format
        """
        lines = []
        snapshot = self.snapshot()
        
        for metric_name, data in snapshot.items():
            # Convert metric name to Prometheus format
            prom_name = metric_name.replace(".", "_").replace("-", "_")
            
            if "p50" in data:
                # Multiple quantiles
                for quantile in ["p50", "p95", "p99"]:
                    lines.append(
                        f'{prom_name}_{quantile} {data[quantile]:.6f}'
                    )
            else:
                # Simple gauge
                lines.append(f'{prom_name} {data["count"]}')
        
        return "\n".join(lines) + "\n"
```

### 3.2 Instrumentation Points

**Engine:**

```python
# src/vjlive3/render/engine.py
class RenderEngine:
    def __init__(self):
        self.telemetry = TelemetryCollector()
        self.context = VJLiveContext()
    
    def render_frame(self):
        """Main render loop with telemetry."""
        frame_start = time.perf_counter()
        
        self.update_context()
        
        # Record frame time components
        context_start = time.perf_counter()
        self.update_context()
        self.telemetry.record("engine.context_update", 
                            (time.perf_counter() - context_start) * 1000)
        
        # Execute plugin batches
        for batch_idx, batch in enumerate(self.schedule):
            batch_start = time.perf_counter()
            self.execute_batch(batch)
            self.telemetry.record(f"engine.batch_{batch_idx}",
                                (time.perf_counter() - batch_start) * 1000)
        
        # Display
        display_start = time.perf_counter()
        self.display(self.context.video)
        self.telemetry.record("engine.display",
                            (time.perf_counter() - display_start) * 1000)
        
        # Total frame time
        frame_time = (time.perf_counter() - frame_start) * 1000
        self.telemetry.record("engine.frame_time", frame_time)
        self.telemetry.record("engine.fps", 1000.0 / frame_time)
        
        # Memory usage
        self.telemetry.record("memory.rss_mb", 
                            psutil.Process().memory_info().rss / 1024 / 1024)
        
        # Safety violations
        self.telemetry.increment("safety.violations", self.context.safety_violations)
