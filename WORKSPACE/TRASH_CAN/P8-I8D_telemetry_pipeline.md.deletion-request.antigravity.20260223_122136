def test_record_and_snapshot():
    collector = TelemetryCollector(window_size=10)
    
    # Record values
    for i in range(10):
        collector.record("test.metric", float(i))
    
    snapshot = collector.snapshot()
    assert "test.metric" in snapshot
    assert snapshot["test.metric"]["p50"] == 4.5
    assert snapshot["test.metric"]["p95"] == 9.05

def test_window_size_enforcement():
    collector = TelemetryCollector(window_size=5)
    
    # Record 10 values
    for i in range(10):
        collector.record("test.metric", float(i))
    
    # Should only keep last 5
    values = list(collector.metrics["test.metric"])
    assert len(values) == 5
    assert values == [5.0, 6.0, 7.0, 8.0, 9.0]

def test_counters():
    collector = TelemetryCollector()
    collector.increment("errors", 5)
    collector.increment("errors", 3)
    
    snapshot = collector.snapshot()
    assert snapshot["errors"]["count"] == 8
```

