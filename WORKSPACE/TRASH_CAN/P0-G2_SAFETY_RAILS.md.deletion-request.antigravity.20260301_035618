from dataclasses import dataclass
from typing import Dict, List
from enum import Enum
import time
import logging

class ViolationSeverity(Enum):
    INFO = 'info'
    WARNING = 'warning'
    CRITICAL = 'critical'
    EMERGENCY = 'emergency'

@dataclass
class ComplianceResult:
    is_compliant: bool
    violations: List[Dict]
    overall_severity: ViolationSeverity
    recommended_action: str
    timestamp: float

def validate_safety_compliance(metrics: Dict, component_name: str) -> ComplianceResult:
    """
    Main validation entry point. Checks all metrics against limits.
    
    Returns ComplianceResult with detailed violation information.
    """
    violations = []
    now = time.time()
    
    # Check each metric in severity order
    if 'fps' in metrics:
        fps = metrics['fps']
        if fps < MIN_FPS_WARNING:
            severity = ViolationSeverity.WARNING if fps >= 50 else ViolationSeverity.CRITICAL
            violations.append({
                'metric': 'fps',
                'current_value': fps,
                'limit': MIN_FPS_WARNING,
                'severity': severity,
                'description': f'FPS {fps:.1f} below warning threshold {MIN_FPS_WARNING}'
            })
    
    if 'memory_mb' in metrics:
        mem = metrics['memory_mb']
        if mem > EMERGENCY_STOP_MEMORY_MB:
            violations.append({
                'metric': 'memory_mb',
                'current_value': mem,
                'limit': EMERGENCY_STOP_MEMORY_MB,
                'severity': ViolationSeverity.EMERGENCY,
                'description': f'Memory {mem} MB exceeds emergency stop limit'
            })
        elif mem > MEMORY_CRITICAL_THRESHOLD * MAX_MEMORY_MB:
            violations.append({
                'metric': 'memory_mb',
                'current_value': mem,
                'limit': MEMORY_CRITICAL_THRESHOLD * MAX_MEMORY_MB,
                'severity': ViolationSeverity.CRITICAL,
                'description': f'Memory {mem} MB at critical level'
            })
        elif mem > MEMORY_WARNING_THRESHOLD * MAX_MEMORY_MB:
            violations.append({
                'metric': 'memory_mb',
                'current_value': mem,
                'limit': MEMORY_WARNING_THRESHOLD * MAX_MEMORY_MB,
                'severity': ViolationSeverity.WARNING,
                'description': f'Memory {mem} MB at warning level'
            })
    
    # ... (other metric checks)
    
    # Determine overall severity
    severity_levels = [v['severity'] for v in violations]
    if ViolationSeverity.EMERGENCY in severity_levels:
        overall = ViolationSeverity.EMERGENCY
    elif ViolationSeverity.CRITICAL in severity_levels:
        overall = ViolationSeverity.CRITICAL
    elif ViolationSeverity.WARNING in severity_levels:
        overall = ViolationSeverity.WARNING
    else:
        overall = ViolationSeverity.INFO
    
    # Generate recommended action
    action_map = {
        ViolationSeverity.INFO: 'Continue normal operation',
        ViolationSeverity.WARNING: 'Monitor closely, consider optimization',
        ViolationSeverity.CRITICAL: 'Reduce load, disable non-essential plugins',
        ViolationSeverity.EMERGENCY: 'IMMEDIATE SHUTDOWN: Save state and restart'
    }
    
    return ComplianceResult(
        is_compliant=overall not in [ViolationSeverity.CRITICAL, ViolationSeverity.EMERGENCY],
        violations=violations,
        overall_severity=overall,
        recommended_action=action_map[overall],
        timestamp=now
    )
