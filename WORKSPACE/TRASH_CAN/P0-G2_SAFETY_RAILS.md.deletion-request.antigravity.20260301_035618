class SafetyMonitor:
    """
    Continuous safety monitoring for running system.
    
    Tracks violations over time and implements escalation logic.
    """
    
    def __init__(self, check_interval: float = 5.0):
        self.check_interval = check_interval
        self.violation_history = []
        self.consecutive_violations = 0
        self.last_check_time = 0
        
    def update(self, current_metrics: Dict) -> ComplianceResult:
        """
        Periodic update called by performance monitor.
        
        Implements escalation: transient violations are forgiven after
        3 clean checks, persistent violations escalate severity.
        """
        result = validate_safety_compliance(current_metrics, 'system', 'core')
        
        # Track consecutive violations
        if result.overall_severity != ViolationSeverity.INFO:
            self.consecutive_violations += 1
        else:
            self.consecutive_violations = 0
            
        # Escalate based on persistence
        if self.consecutive_violations >= 10:
            # Emergency escalation for persistent critical issues
            for v in result.violations:
                if v['severity'] == ViolationSeverity.CRITICAL:
                    v['severity'] = ViolationSeverity.EMERGENCY
                    v['description'] += ' [ESCALATED: 10+ consecutive]'
            result.overall_severity = ViolationSeverity.EMERGENCY
            result.is_compliant = False
            result.recommended_action = 'IMMEDIATE SHUTDOWN: Persistent critical violation'
            
        self.violation_history.append({
            'timestamp': result.timestamp,
            'severity': result.overall_severity,
            'violations': result.violations
        })
        
        # Keep history to last 1000 entries
        if len(self.violation_history) > 1000:
            self.violation_history = self.violation_history[-1000:]
            
        return result
