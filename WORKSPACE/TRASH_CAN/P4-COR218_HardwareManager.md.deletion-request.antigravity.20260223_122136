### Device Discovery
```python
class DeviceDiscovery:
    """Background service for hardware hot-plug detection."""

    def __init__(self, hardware_manager: HardwareManager):
        self.hardware_manager = hardware_manager
        self._monitors: Dict[DeviceType, DeviceMonitor] = {}

    def start(self) -> None:
        """Start all device monitors."""
        for monitor in self._monitors.values():
            monitor.start()

    def stop(self) -> None:
        """Stop all device monitors."""
        for monitor in self._monitors.values():
            monitor.stop()

    def register_monitor(self, device_type: DeviceType, monitor: DeviceMonitor) -> None:
        """Register a device monitor for a specific device type."""
        self._monitors[device_type] = monitor

