def test_multi_agent_cooperation():
    """Multiple agents should control same plugin without conflict."""
    agent1 = DancingAgent("agent_001")
    agent2 = DancingAgent("agent_002")
    plugin = DepthMotionTransferPlugin()
    plugin.agent_control_mappings = {
        "agent_001": ["zoom"],
        "agent_002": ["displacement_strength"],
    }
    
    bridge = AgentBridge()
    bridge.register_agent(agent1, {"zoom": {}})
    bridge.register_agent(agent2, {"displacement_strength": {}})
    
    context = VJLiveContext()
    
    # Set agent states
    agent1.zoom = 0.3
    agent2.displacement_strength = 0.7
    
    bridge.publish_controls(context)
    
    # Plugin should see both controls
    assert context.agent_controls["agent_001.zoom"] == 0.3
    assert context.agent_controls["agent_002.displacement_strength"] == 0.7
    
    # Apply
    params = {"zoom": 1.0, "displacement_strength": 0.0}
    output = plugin.process(Texture(100, 100), params, context)
    
    # Verify both modulations applied
    assert plugin.last_zoom == pytest.approx(1.3)
    assert plugin.last_displacement == pytest.approx(0.7)

def test_agent_feedback_loop():
    """Plugin feedback should influence agent behavior."""
    agent = AdaptiveAgent("agent_001")
    plugin = DepthMotionTransferPlugin()
    
    # Plugin writes feedback
    context = VJLiveContext()
    context.plugin_feedback[f"{plugin.id}.energy_absorbed"] = 0.9  # High energy use
    
    # Agent reads feedback and adapts
    agent.step(context)
    
    # Agent should have reduced energy due to high plugin cost
    assert agent.energy < 1.0  # Conserved energy

def test_agent_control_schema_validation():
    """Agent controls should conform to registered schema."""
    registry = ControlSchemaRegistry()
    registry.register_agent_controls("agent_001", {
        "zoom": {"type": "float", "min": 0.1, "max": 10.0},
        "hue": {"type": "float", "min": 0.0, "max": 360.0},
    })
    
    # Valid values
    assert registry.validate_control("agent_001", "zoom", 2.5)
    assert registry.validate_control("agent_001", "hue", 180.0)
    
    # Out of range
