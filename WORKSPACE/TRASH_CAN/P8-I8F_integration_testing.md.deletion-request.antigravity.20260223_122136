### 5.6 Longevity Tests

**Purpose**: Verify system stability over extended runs.

**Duration**: 24 hours (run overnight)

**Tests:**

```python
def test_24h_continuous_run():
    """System should run 24 hours without crash or memory leak."""
    import psutil
    process = psutil.Process()
    
    engine = RenderEngine()
    engine.active_plugins = [DepthBlurPlugin(id=f"blur_{i}") for i in range(30)]
    
    # Run for 24 hours (in production would be 24h, in CI maybe 1h)
    duration_hours = 1  # Reduced for CI
    frames_per_second = 60
    total_frames = int(duration_hours * 3600 * frames_per_second)
    
    # Sample memory every 1000 frames
    memory_samples = []
    for frame in range(total_frames):
        engine.render_frame()
        
        if frame % 1000 == 0:
            memory_mb = process.memory_info().rss / 1024 / 1024
            memory_samples.append(memory_mb)
            print(f"Frame {frame}/{total_frames}, Memory: {memory_mb:.1f}MB")
    
    # Check for memory leak (linear regression)
    if len(memory_samples) > 10:
        x = np.arange(len(memory_samples))
        slope = np.polyfit(x, memory_samples, 1)[0]
        # Allow 1MB per hour growth
        assert slope < 1.0, f"Memory leak detected: {slope:.3f} MB/sample"
    
    # Should not have crashed
    assert True

def test_preset_save_load_stress():
    """Repeated save/load should not accumulate resources."""
    with tempfile.TemporaryDirectory() as tmp:
        manager = ConfigManager(Path(tmp))
        plugin = DepthBlurPlugin(id="blur1")
        
        initial_memory = psutil.Process().memory_info().rss
        
        for i in range(1000):
            manager.save_preset(f"preset_{i}", [plugin])
            plugin2 = DepthBlurPlugin(id="blur1")
            manager.load_preset(f"preset_{i}", [plugin2])
            del plugin2
        
        final_memory = psutil.Process().memory_info().rss
        growth = final_memory - initial_memory
        
        # Allow 10MB growth over 1000 iterations
        assert growth < 10 * 1024 * 1024, f"Memory growth: {growth/1024/1024:.1f}MB"
```

