def test_context_population():
    """Engine should populate all context fields correctly."""
    engine = RenderEngine()
    engine.video_manager = MockVideoManager()
    engine.audio_engine = MockAudioEngine()
    
    engine.render_frame()
    
    context = engine.context
    assert context.video is not None
