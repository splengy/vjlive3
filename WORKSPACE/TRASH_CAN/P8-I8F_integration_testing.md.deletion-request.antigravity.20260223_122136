    assert context.agent_controls["agent_001.displacement"] == 0.3
    
    # Plugin applies modulation
    params = {"zoom": 1.0, "displacement": 0.0}
    output = plugin.process(Texture(100, 100), params, context)
    
    # Verify modulation applied
    assert plugin.last_zoom == pytest.approx(1.0 + 0.5 * 0.5)  # base + modulation*0.5
    assert plugin.last_displacement == pytest.approx(0.3)

