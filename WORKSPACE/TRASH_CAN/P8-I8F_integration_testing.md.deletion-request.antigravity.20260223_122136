### 5.10 Regression Tests

**Purpose**: Full system test to catch regressions.

**Duration**: ~4 hours

**Test Scenario:**
1. Initialize engine with 50 plugins
2. Load preset
3. Run for 1000 frames
4. Verify FPS ≥ 58
5. Verify memory stable
6. Verify all telemetry recorded
7. Save preset
8. Shutdown
9. Restart and load preset
10. Verify state restored correctly

```python
def test_full_system_regression():
    """Complete system test covering all wiring components."""
    with tempfile.TemporaryDirectory() as tmp:
        # Setup
        project_root = Path(tmp)
        app = VJLiveApp(project_root)
        
        # Load 50 plugins
        app.plugins = [DepthBlurPlugin(id=f"blur_{i}") for i in range(50)]
        
        # Add 4 agents
        bridge = AgentBridge()
        for i in range(4):
            agent = DancingAgent(f"agent_{i}")
            bridge.register_agent(agent, {"intensity": {}})
        app.agent_bridge = bridge
        
        # Run 1000 frames
        frame_times = []
        for i in range(1000):
            start = time.perf_counter()
            app.engine.render_frame()
            frame_times.append(time.perf_counter() - start)
            
            # Agents step every frame
            bridge.publish_controls(app.engine.context)
        
        # Verify performance
        fps = 1.0 / np.median(frame_times)
        assert fps >= 58.0, f"FPS regression: {fps:.2f}"
        
        # Verify telemetry
        snapshot = app.engine.telemetry.snapshot()
        assert "engine.fps" in snapshot
        assert len(snapshot) > 50  # Many metrics
        
        # Save preset
        app.save_preset("regression_test")
        assert (project_root / "presets" / "regression_test.json").exists()
        
        # Shutdown and restart
        app.shutdown()
        app2 = VJLiveApp(project_root)
        app2.plugins = [DepthBlurPlugin(id=f"blur_{i}") for i in range(50)]
        
        # Load preset
        success = app2.load_preset("regression_test", app2.plugins)
        assert success
        
        # Verify state restored
        for i, plugin in enumerate(app2.plugins):
            original = app.plugins[i]
            assert plugin.get_params() == original.get_params()
