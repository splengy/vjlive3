def test_plugin_crash_recovery():
    """Pipeline should continue if plugin crashes."""
    engine = RenderEngine()
    engine.active_plugins = [
        GoodPlugin(),
        CrashingPlugin(),  # This one crashes every other frame
        GoodPlugin(),
    ]
    
    # Should not crash engine
    for i in range(10):
        engine.render_frame()
    
    # Should have recorded safety violations
    assert engine.context.safety_violations > 0
    
    # Crashing plugin should be temporarily disabled
    crasher = engine.wrapped_plugins[1].plugin
    assert crasher.disabled_until > 0

def test_missing_depth_input():
    """Plugins requiring depth should handle missing input."""
    plugin = DepthBlurPlugin()
    plugin.needs_depth = True
    
    context = VJLiveContext()
    context.depth = None  # No depth available
    
    # Should fallback gracefully
    output = plugin.process(Texture(100, 100), {}, context)
    assert output is not None
    # Should be input passthrough
    assert output.data == context.video.data

