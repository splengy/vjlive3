### 5.3 Performance Tests

**Purpose**: Verify system meets performance requirements.

**Duration**: ~1 hour

**Tests:**

```python
def test_fps_under_load():
    """Engine should maintain 58+ FPS with 50 plugins."""
    engine = RenderEngine()
    engine.active_plugins = [DepthBlurPlugin(id=f"blur_{i}") for i in range(50)]
    
    # Warm up
    for _ in range(100):
        engine.render_frame()
    
    # Measure
    frame_times = []
    for _ in range(600):  # 10 seconds at 60Hz
        start = time.perf_counter()
        engine.render_frame()
        frame_times.append(time.perf_counter() - start)
    
    fps = 1.0 / np.median(frame_times)
    assert fps >= 58.0, f"FPS too low: {fps:.2f}"

def test_memory_leak():
    """Memory should not grow over 1000 frames."""
    import psutil
    process = psutil.Process()
    
    engine = RenderEngine()
    engine.active_plugins = [DepthBlurPlugin(id=f"blur_{i}") for i in range(30)]
    
    # Warm up
    for _ in range(100):
        engine.render_frame()
    
    # Measure memory over 1000 frames
    memory_samples = []
    for i in range(1000):
        engine.render_frame()
        if i % 100 == 0:
            memory_samples.append(process.memory_info().rss / 1024 / 1024)  # MB
    
    # Check for monotonic increase
    # Allow 5% variance
    baseline = memory_samples[0]
    final = memory_samples[-1]
    growth = final - baseline
    assert growth < baseline * 0.05, f"Memory leak detected: {growth:.2f}MB growth"

def test_telemetry_overhead():
    """Telemetry should add <1% overhead."""
    engine1 = RenderEngine()
    engine1.telemetry = None  # No telemetry
    
    engine2 = RenderEngine()
    engine2.telemetry = TelemetryCollector()
    
    # Run both engines for 1000 frames
    n_frames = 1000
    
    start = time.perf_counter()
    for _ in range(n_frames):
        engine1.render_frame()
    time_no_telemetry = time.perf_counter() - start
    
    start = time.perf_counter()
    for _ in range(n_frames):
        engine2.render_frame()
    time_with_telemetry = time.perf_counter() - start
    
    overhead = (time_with_telemetry - time_no_telemetry) / time_no_telemetry
    assert overhead < 0.01, f"Telemetry overhead too high: {overhead*100:.2f}%"

def test_scheduler_overhead():
    """Scheduler should add <0.5ms per frame."""
    engine = RenderEngine()
    engine.active_plugins = [DepthBlurPlugin(id=f"blur_{i}") for i in range(100)]
    
    # Pre-compute schedule (one-time cost)
    engine.schedule = engine.scheduler.schedule(engine.active_plugins)
    
    # Measure schedule execution overhead
    times = []
    for _ in range(1000):
        start = time.perf_counter()
        # Just execute the schedule (no actual plugin work)
        for batch in engine.schedule:
            pass
        times.append(time.perf_counter() - start)
    
    avg_overhead = np.median(times) * 1000  # ms
    assert avg_overhead < 0.5, f"Scheduler overhead: {avg_overhead:.3f}ms"

def test_agent_control_latency():
    """Agent control should be visible to plugin within 1 frame."""
    agent = DancingAgent("agent_001")
    plugin = DepthMotionTransferPlugin()
    plugin.agent_control_mappings = {"agent_001": ["zoom"]}
    
    bridge = AgentBridge()
    bridge.register_agent(agent, {"zoom": {}})
    
    engine = RenderEngine()
    engine.agent_bridge = bridge
    engine.active_plugins = [plugin]
    
    # Frame 1: Agent sets control
    agent.zoom = 0.5
    bridge.publish_controls(engine.context)
    
    # Plugin should see it immediately
    assert engine.context.agent_controls["agent_001.zoom"] == 0.5
