### 6.2 CI/CD Pipeline

**GitHub Actions Workflow:**

```yaml
name: Integration Tests

on:
  push:
    branches: [main, develop]
  pull_request:

jobs:
  test:
    runs-on: ubuntu-latest
    container:
      image: nvidia/cuda:11.8-runtime-ubuntu22.04
      options: --gpus all
    
    steps:
      - uses: actions/checkout@v3
      
      - name: Install dependencies
        run: |
          apt-get update && apt-get install -y xvfb
          pip install -r requirements.txt
          pip install pytest pytest-xdist pytest-benchmark pytest-cov
      
      - name: Start Xvfb
        run: Xvfb :99 -screen 0 1920x1080x24 &
      
      - name: Run smoke tests
        run: xvfb-run -a pytest tests/integration/ -m "smoke" -v --tb=short
      
      - name: Run functional tests
        run: xvfb-run -a pytest tests/integration/ -m "functional" -v --tb=short
      
      - name: Run performance tests
        run: xvfb-run -a pytest tests/integration/test_performance.py -v --tb=short
      
      - name: Run failure injection tests
        run: xvfb-run -a pytest tests/integration/test_failure_injection.py -v --tb=short
      
      - name: Upload coverage
        uses: codecov/codecov-action@v3
        with:
          files: ./coverage.xml
```

