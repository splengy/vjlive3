    assert context.spectrum is not None
    assert context.features is not None
    assert context.midi_messages is not None
    assert context.osc_values is not None
    assert context.lfo_values is not None
    assert context.agent_states is not None
    assert context.time > 0
    assert context.frame == 1
    assert context.fps > 0

def test_plugin_scheduler():
    """Scheduler should correctly resolve dependencies."""
    plugins = [
        DepthSourcePlugin(id="depth_source", provides=["depth"]),
        AudioSourcePlugin(id="audio_source", provides=["audio"]),
        DepthBlurPlugin(id="depth_blur", needs=["depth"], provides=["video"]),
        AudioReactivePlugin(id="audio_react", needs=["audio", "video"], provides=[]),
    ]
    
    scheduler = PluginScheduler()
    batches = scheduler.schedule(plugins)
    
    # Should have 3 batches:
    # Batch 0: depth_source, audio_source (parallel)
    # Batch 1: depth_blur (needs depth)
    # Batch 2: audio_react (needs audio and video from depth_blur)
    assert len(batches) == 3
    assert set(batches[0]) == {plugins[0], plugins[1]}
    assert batches[1] == [plugins[2]]
    assert batches[2] == [plugins[3]]

def test_safe_plugin_wrapper():
    """Wrapper should catch errors and provide fallback."""
    failing_plugin = FailingPlugin(fail_count=3)
    wrapper = SafePluginWrapper(failing_plugin, error_threshold=3)
    
    context = VJLiveContext()
    
    # First 3 calls should fail but not crash
    for i in range(3):
        try:
            wrapper.process(Texture(10, 10), {}, context)
        except:
            pass
        assert wrapper.error_count == i + 1
    
    # 4th call should return fallback without executing plugin
    output = wrapper.process(Texture(10, 10), {}, context)
    assert output == wrapper.fallback_texture
    assert wrapper.disabled_until > context.time

def test_agent_plugin_communication():
    """Agent should publish controls that plugin can read."""
    agent = DancingAgent("agent_001")
    plugin = DepthMotionTransferPlugin()
    plugin.agent_control_mappings = {"agent_001": ["zoom", "displacement"]}
    
    bridge = AgentBridge()
    bridge.register_agent(agent, {"zoom": {}, "displacement": {}})
    
    context = VJLiveContext()
    
    # Agent updates state
