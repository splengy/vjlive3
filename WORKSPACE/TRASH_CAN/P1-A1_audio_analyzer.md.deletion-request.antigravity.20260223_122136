## Public Interface

### Main Entry Point

```python
# src/vjlive3/audio/analyzer.py
class AudioAnalyzer:
    def __init__(
        self,
        sample_rate: int = 44100,
        buffer_size: int = 2048,
        device_index: Optional[int] = None
    )
    
    def start(self) -> None
    def stop(self) -> None
    def is_running(self) -> bool
    
    # Current analysis snapshot (thread-safe)
    def get_current_analysis(self) -> Dict[str, Any]:
        """
        Returns:
            {
                'bass': float,      # 0.0-1.0 normalized
                'mid': float,       # 0.0-1.0 normalized
                'high': float,      # 0.0-1.0 normalized
                'kick': bool,       # Beat detected this frame
                'snare': bool,      # Snare hit detected
                'bpm': float,       # Estimated BPM
                'rms': float,       # Overall volume
                'peak': float,      # Instantaneous peak
                'spectrum': List[float],  # FFT magnitude bins
                'waveform': List[float],  # Downsampled waveform
                'beat_phase': float,      # 0-1 phase within beat
                'confidence': float       # Detection confidence
            }
        """
    
    # Simulation mode for testing
    def set_simulation_mode(self, enabled: bool) -> None
    def update_simulation(self, analysis: Dict[str, Any]) -> None
```

### Reactivity Bus

```python
# src/vjlive3/audio/bus.py
class AudioReactivityBus:
    def __init__(self):
        self.subscribers: List[Callable] = []
    
    def subscribe(self, callback: Callable[[Dict], None]) -> None
    def unsubscribe(self, callback: Callable[[Dict], None]) -> None
    def publish(self, analysis: Dict[str, Any]) -> None
    
# Global instance
audio_bus = AudioReactivityBus()
