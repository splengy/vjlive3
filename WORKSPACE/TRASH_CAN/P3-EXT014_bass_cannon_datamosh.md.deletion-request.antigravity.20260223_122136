## 5. GLSL Fragment Shader (144 lines)

```glsl
#version 330 core
in vec2 v_uv;
out vec4 fragColor;

uniform sampler2D tex0;
uniform sampler2D texPrev;
uniform sampler2D depth_tex;
uniform sampler2D tex1;
uniform float time;
uniform vec2 resolution;

uniform float u_cannon_power;      // 0-1
uniform float u_shockwave_speed;   // 0-10
uniform float u_recoil;            // 0-1
uniform float u_muzzle_flash;      // 0-1
uniform float u_debris_scatter;    // 0-1
uniform float u_bass_threshold;    // 0-1 (unused in shader, set for info)
uniform float u_impact_radius;     // 0-1
uniform float u_distortion;        // 0-1
uniform float u_chroma_blast;      // 0-1
uniform float u_thermal_exhaust;   // 0-1
uniform float u_depth_penetration; // 0-1
uniform float u_decay;             // 0-1

uniform float u_mix;

float hash(vec2 p) {
    vec3 p3 = fract(vec3(p.xyx) * 0.1031);
    p3 += dot(p3, p3.yzx + 33.33);
    return fract((p3.x + p3.y) * p3.z);
}

void main() {
    vec2 uv = v_uv;
    vec2 texel = 1.0 / resolution;

    bool hasDual = (texture(tex1, vec2(0.5)).r +
                    texture(tex1, vec2(0.5)).g +
                    texture(tex1, vec2(0.5)).b) > 0.001;
    float depth = texture(depth_tex, uv).r;

    // Radial coordinates from center
    vec2 p = uv - 0.5;
    float r = length(p);
    float a = atan(p.y, p.x);

    // Shockwave wavefront: repeats based on time and speed
    float wavePhase = time * u_shockwave_speed;
    float waveDist = fract(wavePhase); // 0.0 to 1.0 (normalized distance)

    // Blast envelope: strength decays with distance, stops at penetration limit
    float blastStr = u_cannon_power * (1.0 - waveDist) * step(waveDist, u_depth_penetration);

    // Shockwave ring: narrow ring at waveDist position
    float shock = smoothstep(0.0, 0.1, abs(r - waveDist));
    shock = 1.0 - shock;
    shock = pow(shock, 8.0); // Sharpen to thin ring

    // Apply distortion: pull pixels toward center as wave passes
    vec2 shockUV = p * (1.0 - shock * u_distortion * 0.1 * blastStr);

    // Recoil: screen shake during blast
    vec2 recoil = vec2(0.0);
    if (blastStr > 0.1) {
        float shake = hash(vec2(time, 0.0)) - 0.5;
        recoil = vec2(shake * u_recoil * 0.1 * (1.0 - waveDist));
    }

    vec2 finalUV = shockUV + 0.5 + recoil;
    finalUV = clamp(finalUV, 0.0, 1.0);

    // Debris scatter: random pixel displacement during blast
    if (u_debris_scatter > 0.0) {
        float debris = hash(uv * 50.0 + time);
        if (debris > 0.95) {
            finalUV += (vec2(hash(uv), hash(uv+1.0)) - 0.5) * u_debris_scatter * 0.1 * blastStr;
        }
    }

    // Chroma blast: RGB split based on blast strength
    vec4 color;
    if (u_chroma_blast > 0.0) {
        float off = u_chroma_blast * 0.02 * blastStr;
        float rCol = hasDual ? texture(tex1, finalUV + vec2(off, 0)).r : texture(tex0, finalUV + vec2(off, 0)).r;
        float gCol = hasDual ? texture(tex1, finalUV).g : texture(tex0, finalUV).g;
        float bCol = hasDual ? texture(tex1, finalUV - vec2(off, 0)).b : texture(tex0, finalUV - vec2(off, 0)).b;
        color = vec4(rCol, gCol, bCol, 1.0);
    } else {
        color = hasDual ? texture(tex1, finalUV) : texture(tex0, finalUV);
    }

    // Muzzle flash: whiteout near center when wave is at origin
    if (u_muzzle_flash > 0.0 && waveDist < 0.1) {
        float flash = (0.1 - waveDist) * 10.0 * u_muzzle_flash * u_cannon_power;
        color.rgb = mix(color.rgb, vec3(1.0), flash);
    }

    // Thermal exhaust: feedback trails where blast is NOT active
    vec4 prev = texture(texPrev, finalUV);
    color = mix(color, prev, u_thermal_exhaust * 0.3 * (1.0 - blastStr));

    // Impact ring: orange glow on the shockwave ring
    color.rgb += vec3(1.0, 0.5, 0.2) * shock * blastStr * 2.0;

    // Final blend with original
    vec4 original = hasDual ? texture(tex1, uv) : texture(tex0, uv);
    fragColor = mix(original, color, u_mix);
}
```

