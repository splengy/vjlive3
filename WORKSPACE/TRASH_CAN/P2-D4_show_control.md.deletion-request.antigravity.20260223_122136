## Public Interface

### ShowControl Class

```python
# src/vjlive3/show/control.py
class ShowControl:
    def __init__(self):
        """Initialize show control system"""
    
    def load_show(self, filepath: str) -> Show
    def save_show(self, show: Show, filepath: str) -> None
    
    def create_show(self, name: str, duration: float) -> Show
    def get_current_show(self) -> Optional[Show]
    
    def add_track(self, show: Show, track_type: str, name: str) -> Track
    def add_cue(self, track: Track, start_time: float, duration: float, actions: List[CueAction]) -> Cue
    
    def play(self) -> None
    def pause(self) -> None
    def stop(self) -> None
    def seek(self, time: float) -> None
    
    def get_playback_state(self) -> PlaybackState
    def get_current_time(self) -> float
    def get_remaining_time(self) -> float
    
    def set_timecode_source(self, source: TimecodeSource) -> None
    def get_timecode(self) -> Timecode
```

### Show Data Structure

```python
@dataclass
class Show:
    name: str
    duration: float
    tracks: List[Track]
    metadata: Dict[str, Any]
    created: datetime
    modified: datetime

@dataclass
class Track:
    id: str
    name: str
    type: str  # "lighting", "video", "audio", "effects"
    cues: List[Cue]
    muted: bool = False
    solo: bool = False
    volume: float = 1.0

@dataclass
class Cue:
    id: str
    name: str
    start_time: float
    duration: float
    actions: List[CueAction]
    transition: Transition = Transition.CUT
    follow_action: FollowAction = FollowAction.NONE

@dataclass
class CueAction:
    target: str  # "dmx.universe.1", "effect.scale", etc.
    parameter: str
    value: Any
    fade_time: float = 0.0
```

