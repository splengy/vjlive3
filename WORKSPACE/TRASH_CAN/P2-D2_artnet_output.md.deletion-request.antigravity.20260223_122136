## Public Interface

### DMXEngine Class

```python
# src/vjlive3/core/dmx/engine.py
class DMXEngine:
    def __init__(
        self,
        bind_ip: str = "0.0.0.0",
        artnet_enabled: bool = True,
        sacn_enabled: bool = True
    ):
        """
        Initialize DMX engine with Art-Net and sACN support.
        
        Args:
            bind_ip: IP address to bind to (0.0.0.0 = all interfaces)
            artnet_enabled: Enable Art-Net protocol
            sacn_enabled: Enable sACN protocol
        """
    
    def start(self) -> None
    def stop(self) -> None
    
    def set_universe_data(
        self,
        universe: int,
        data: bytes,  # 512-byte DMX data
        priority: int = 100
    ) -> None
    
    def get_universe_data(self, universe: int) -> bytes
    def get_universe_status(self, universe: int) -> UniverseStatus
    
    def add_fixture(
        self,
        fixture_id: str,
        profile: FixtureProfile,
        start_channel: int,
        universe: int
    ) -> None
    
    def set_fixture_parameter(
        self,
        fixture_id: str,
        parameter: str,
        value: float
    ) -> None
    
    def get_statistics(self) -> DMXStatistics
```

