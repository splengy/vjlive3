### 3.6 Schema & Validation

**Control Schema Registry:**

```python
class ControlSchemaRegistry:
    """Registry for agent→plugin and plugin→agent control schemas."""
    
    def __init__(self):
        self.agent_controls: Dict[str, Dict[str, Any]] = {}  # agent_id → {param: metadata}
        self.plugin_feedback: Dict[str, Dict[str, Any]] = {}  # plugin_id → {metric: metadata}
    
    def register_agent_controls(self, agent_id: str, controls: Dict[str, Dict]):
        """
        Register agent control parameters.
        
        controls = {
            "zoom": {"type": "float", "min": 0.1, "max": 10.0, "default": 1.0},
            "hue": {"type": "float", "min": 0.0, "max": 360.0},
        }
        """
        self.agent_controls[agent_id] = controls
    
    def register_plugin_feedback(self, plugin_id: str, feedback: Dict[str, Dict]):
        """Register plugin feedback metrics."""
        self.plugin_feedback[plugin_id] = feedback
    
    def validate_control(self, agent_id: str, param: str, value: Any) -> bool:
        """Validate that a control value matches schema."""
        if agent_id not in self.agent_controls:
            return False
        if param not in self.agent_controls[agent_id]:
            return False
        
        schema = self.agent_controls[agent_id][param]
        # Type checking, range checking, etc.
        # ...
        return True
```

