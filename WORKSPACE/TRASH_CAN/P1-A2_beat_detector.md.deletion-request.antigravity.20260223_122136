        """
    
    def process(self, spectrum: np.ndarray, rms: float) -> BeatInfo:
        """
        Process audio frame and detect beats.
        
        Args:
            spectrum: FFT magnitude array
            rms: Current RMS volume
            
        Returns:
            BeatInfo: Detection results
        """
    
    def get_beat_info(self) -> BeatInfo:
