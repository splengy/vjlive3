# migration_script.py
import ast
import os
from pathlib import Path

class ContextMigrator(ast.NodeTransformer):
    """Migrate plugin context access patterns."""
    
    def visit_FunctionDef(self, node):
        # Update function signature
        if node.name == "process":
            # Add context type hint
            node.args.args.append(ast.arg(arg='context', annotation=ast.Name(id='VJLiveContext')))
        return node
    
    def visit_Call(self, node):
        # Migrate context.inputs.get() to direct access
        if (isinstance(node.func, ast.Attribute) and
            isinstance(node.func.value, ast.Name) and
            node.func.value.id == 'context' and
            node.func.attr == 'inputs'):
            # Convert to direct attribute access
            return ast.Attribute(
                value=ast.Name(id='context', ctx=ast.Load()),
                attr=node.args[0].s,  # Field name
                ctx=ast.Load()
            )
        return node
```

