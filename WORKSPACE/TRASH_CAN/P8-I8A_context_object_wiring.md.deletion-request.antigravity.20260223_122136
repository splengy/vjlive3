import pytest
from vjlive3.core.context import VJLiveContext, AudioState

def test_context_creation():
    """Test basic context creation."""
    context = VJLiveContext()
    assert context.time >= 0
    assert context.frame == 0
    assert context.fps == 60.0

def test_audio_state():
    """Test audio state initialization."""
    audio = AudioState(
        waveform=np.zeros(1024),
        fft=np.zeros(512),
        spectrum=np.zeros(512),
        onset=0.5,
        bpm=128.0,
        bands={"bass": 0.8, "mid": 0.6, "treble": 0.4},
        rms=0.2
    )
    assert len(audio.waveform) == 1024
    assert len(audio.fft) == 512
    assert audio.bpm == 128.0

def test_schema_validation():
    """Test schema validation catches errors."""
    context = VJLiveContext()
    
    # Valid case
    context.video = Texture(1920, 1080)
    context.validate_schema()
    
    # Invalid case
    with pytest.raises(AssertionError):
        context.video = "not a texture"  # Should fail validation
        context.validate_schema()
```

