## 3. Solution Architecture

### 3.1 VJLiveContext Class Definition

```python
from dataclasses import dataclass, field
from typing import Optional, Dict, List, Any, Callable
import numpy as np
from pathlib import Path
from datetime import datetime

@dataclass
class AudioState:
    """Complete audio analysis state."""
    waveform: np.ndarray = None          # Raw waveform (1024 samples)
    fft: np.ndarray = None               # FFT magnitudes (512 bins)
    spectrum: np.ndarray = None          # Normalized spectrum (0-1)
    onset: float = 0.0                   # Onset detection (0-1)
    bpm: float = 120.0                   # Estimated BPM
    bands: Dict[str, float] = field(default_factory=dict)  # Bass/mid/treble
    rms: float = 0.0                     # Root mean square
    
@dataclass
class AgentState:
    """Agent position and velocity in 16D manifold."""
    id: str
    position: List[float] = field(default_factory=lambda: [0.0]*16)
    velocity: List[float] = field(default_factory=lambda: [0.0]*16)
    acceleration: List[float] = field(default_factory=lambda: [0.0]*16)
    energy: float = 0.0
    age: float = 0.0
    
@dataclass
class VJLiveContext:
    """Central context object passed through entire pipeline."""
    
    # Video pipeline
    video: Optional[Texture] = None          # Current video frame (RGBA)
    depth: Optional[Texture] = None          # Depth map (R16F)
    background: Optional[Texture] = None     # Background layer (RGBA)
    
    # Audio pipeline
    audio: Optional[AudioState] = None       # Complete audio analysis
    spectrum: Optional[np.ndarray] = None    # Frequency bins (0-1)
    features: Optional[Dict[str, float]] = None  # Band energies, RMS, etc.
    
    # MIDI/OSC
    midi_messages: List[Dict] = field(default_factory=list)  # Recent MIDI events
    osc_values: Dict[str, float] = field(default_factory=dict)  # Latest OSC values
    
    # Modulation
    lfo_values: Dict[str, float] = field(default_factory=dict)  # Active LFO outputs
    envelope_states: Dict[str, float] = field(default_factory=dict)  # Envelope generators
    
    # Agent system
    agent_states: List[AgentState] = field(default_factory=list)  # Current agent positions
    agent_controls: Dict[str, Any] = field(default_factory=dict)  # Agent→plugin commands
    
    # System
    time: float = 0.0                        # Monotonic time in seconds
    frame: int = 0                           # Frame counter
    dt: float = 0.016                        # Delta time (target 60Hz)
    fps: float = 60.0                        # Instant FPS
    memory_usage: int = 0                    # RSS in bytes
    safety_violations: int = 0               # Rail violation count
    
    # Configuration
    preset_name: str = "default"
    project_root: Path = field(default_factory=lambda: Path("."))
    
    # Runtime state
    is_paused: bool = False
    is_recording: bool = False
    is_fullscreen: bool = False
    
    def __post_init__(self):
        """Validate and initialize context."""
        self.validate_schema()
        self.initialize_defaults()
    
    def validate_schema(self):
        """Ensure all fields conform to expected types."""
        # Type validation for critical fields
        assert isinstance(self.time, (float, int)), "time must be numeric"
        assert isinstance(self.frame, int), "frame must be integer"
        assert isinstance(self.fps, (float, int)), "fps must be numeric"
        
        # Optional fields can be None
        if self.video is not None:
            assert isinstance(self.video, Texture), "video must be Texture"
        
        if self.audio is not None:
            assert isinstance(self.audio, AudioState), "audio must be AudioState"
    
    def initialize_defaults(self):
        """Set sensible defaults for optional fields."""
        if self.audio is None:
            self.audio = AudioState()
        
        if self.spectrum is None:
            self.spectrum = np.zeros(512)
        
        if self.features is None:
            self.features = {"bass": 0.0, "mid": 0.0, "treble": 0.0, "rms": 0.0}
    
    def snapshot(self) -> Dict[str, Any]:
        """Return serializable snapshot for debugging."""
        return {
            "time": self.time,
            "frame": self.frame,
            "fps": self.fps,
            "memory_usage": self.memory_usage,
            "safety_violations": self.safety_violations,
            "preset_name": self.preset_name,
            "is_paused": self.is_paused,
            "video": bool(self.video),
            "depth": bool(self.depth),
            "audio": bool(self.audio),
            "agent_count": len(self.agent_states),
        }
```

### 3.2 Integration Points

#### 3.2.1 Engine Integration

**Current**: `engine.py` creates context dict manually:

```python
# Current engine.py
class RenderEngine:
    def __init__(self):
        self.context = {}
    
    def update_context(self):
        self.context["video"] = self.video_manager.get_frame()
        self.context["audio"] = self.audio_engine.get_audio_state()
        # ...
```

**New**: Use `VJLiveContext`:

```python
# New engine.py
from vjlive3.core.context import VJLiveContext

class RenderEngine:
    def __init__(self):
        self.context = VJLiveContext()
        self.context.project_root = Path(__file__).parent.parent
    
    def update_context(self):
        """Populate context each frame."""
        # Video pipeline
        self.context.video = self.video_manager.get_frame()
        self.context.depth = self.depth_manager.get_depth_map()
        
        # Audio pipeline
        audio_state = self.audio_engine.get_audio_state()
        self.context.audio = audio_state
        self.context.spectrum = audio_state.spectrum if audio_state else np.zeros(512)
        self.context.features = {
            "bass": audio_state.bands.get("bass", 0.0),
            "mid": audio_state.bands.get("mid", 0.0),
            "treble": audio_state.bands.get("treble", 0.0),
            "rms": audio_state.rms if audio_state else 0.0,
        }
        
        # System
        self.context.time = time.monotonic()
        self.context.frame += 1
        self.context.fps = self.calculate_fps()
        self.context.memory_usage = self.get_memory_usage()
        
        # Validate context
        self.context.validate_schema()
```

#### 3.2.2 Plugin Integration

**Current**: Plugins access inputs via `context.inputs`:

```python
# Current plugin
class DepthBlurPlugin(EffectPlugin):
    def process(self, input_texture, params, context):
        depth = context.inputs.get("depth")
        if depth is None:
            return input_texture
        
        return self.blur_with_depth(input_texture, depth, params)
```

**New**: Direct attribute access:

```python
# New plugin
class DepthBlurPlugin(EffectPlugin):
    def process(self, input_texture, params, context: VJLiveContext):
        """Process with depth map from context."""
        if context.depth is None:
            # Graceful fallback
            return input_texture
        
        # Use depth directly
        return self.blur_with_depth(input_texture, context.depth, params)
```

**Backward Compatibility**:
- Create adapter: `context.inputs = context.__dict__`
- Maintain `context.inputs` dict for existing plugins
- Phase out over 2-3 releases

#### 3.2.3 Agent Integration

**Current**: Agents write to `context.agent_states` list:

```python
# Current agent
class Agent:
    def step(self, context):
        context.agent_states.append(self.get_state())
```

**New**: Use `AgentState` dataclass:

```python
# New agent
class Agent:
    def step(self, context: VJLiveContext):
        state = AgentState(
            id=self.id,
            position=self.position,
            velocity=self.velocity,
            energy=self.energy,
            age=self.age
        )
        context.agent_states.append(state)
        
        # Write controls for plugins
        context.agent_controls[f"{self.id}.param_x"] = self.position[0]
        context.agent_controls[f"{self.id}.param_y"] = self.position[1]
```

