# test_performance.py
import time
import pytest
from vjlive3.core.context import VJLiveContext

def test_context_performance():
    """Benchmark context creation and access."""
    iterations = 10000
    
    start = time.perf_counter()
    for _ in range(iterations):
        context = VJLiveContext()
        context.time = time.monotonic()
        context.frame += 1
        context.fps = 60.0
        context.memory_usage = 100
    
    elapsed = time.perf_counter() - start
    per_iteration = elapsed / iterations * 1000  # ms
    
    assert per_iteration < 0.1, f"Context creation too slow: {per_iteration}ms"
