# src/vjlive3/ui/cli.py
def create_cli_parser():
    parser = argparse.ArgumentParser(description="VJLive3 Command Line Interface")
    
    # Preset commands
    preset_group = parser.add_argument_group("Preset Management")
    preset_group.add_argument("--preset-save", metavar="NAME",
                             help="Save current plugin states as preset")
    preset_group.add_argument("--preset-load", metavar="NAME",
                             help="Load preset by name")
    preset_group.add_argument("--preset-list", action="store_true",
                             help="List all available presets")
    preset_group.add_argument("--preset-delete", metavar="NAME",
                             help="Delete a preset")
    
    # Project commands
    project_group = parser.add_argument_group("Project Management")
    project_group.add_argument("--project-save", metavar="NAME",
                              help="Save complete project")
    project_group.add_argument("--project-load", metavar="NAME",
                              help="Load project by name")
    project_group.add_argument("--project-list", action="store_true",
                              help="List all available projects")
    
    return parser

def main():
    parser = create_cli_parser()
    args = parser.parse_args()
    
    # Initialize app
    app = VJLiveApp(project_root=Path("."))
    
    # Handle commands
    if args.preset_save:
        app.save_preset(args.preset_save)
    elif args.preset_load:
        app.load_preset(args.preset_load)
    elif args.preset_list:
        presets = app.config_manager.list_presets()
        for p in presets:
            print(f"{p['name']} ({p['plugin_count']} plugins)")
    elif args.preset_delete:
        app.config_manager.delete_preset(args.preset_delete)
    elif args.project_save:
        app.save_project(args.project_save)
    elif args.project_load:
        app.load_project(args.project_load)
    elif args.project_list:
        projects = app.config_manager.list_projects()
        for p in projects:
            print(f"{p['name']} ({p['plugin_count']} plugins)")
    else:
        # Normal GUI mode
        app.run()
