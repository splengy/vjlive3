## 3. Solution Architecture

### 3.1 ConfigManager Class

**Purpose**: Central configuration authority for all VJLive3 settings.

```python
from dataclasses import dataclass, asdict
from typing import Dict, List, Optional, Any
from pathlib import Path
import json
import shutil

@dataclass
class PluginState:
    """Serializable state of a single plugin."""
    id: str
    class_name: str
    params: Dict[str, Any]
    enabled: bool = True
    position: Optional[Dict] = None  # For UI layout
    
    def to_dict(self) -> Dict:
        return asdict(self)
    
    @classmethod
    def from_dict(cls, data: Dict) -> 'PluginState':
        return cls(**data)

@dataclass
class Project:
    """Complete project state."""
    name: str
    version: str = "1.0.0"
    plugins: List[PluginState] = field(default_factory=list)
    metadata: Dict[str, Any] = field(default_factory=dict)
    created_at: float = 0.0
    modified_at: float = 0.0
    
    def to_dict(self) -> Dict:
        return asdict(self)
    
    @classmethod
    def from_dict(cls, data: Dict) -> 'Project':
        # Handle version migration
        data = migrate_project(data)
        return cls(**data)

class ConfigManager:
    """Central configuration and preset management."""
    
    def __init__(self, project_root: Path):
        self.project_root = project_root
        self.presets_dir = project_root / "presets"
        self.projects_dir = project_root / "projects"
        self.backup_dir = project_root / "presets_backup"
        
        # Ensure directories exist
        self.presets_dir.mkdir(parents=True, exist_ok=True)
        self.projects_dir.mkdir(parents=True, exist_ok=True)
        self.backup_dir.mkdir(parents=True, exist_ok=True)
        
        # Cloud sync client (optional)
        self.cloud_client: Optional[CloudSyncClient] = None
        
        # Schema version
        self.schema_version = "1.0.0"
    
    def save_preset(self, name: str, plugins: List[EffectPlugin], 
                   metadata: Optional[Dict] = None) -> Path:
        """
        Save current plugin states as a preset.
        
        Args:
            name: Preset name (no spaces, alphanumeric)
            plugins: List of plugin instances
            metadata: Optional metadata (author, tags, etc.)
            
        Returns:
            Path to saved preset file
        """
        # Validate name
        if not re.match(r'^[a-zA-Z0-9_-]+$', name):
            raise ValueError(f"Invalid preset name: {name}")
        
        # Build preset data
        preset = {
            "schema_version": self.schema_version,
            "name": name,
            "created_at": time.time(),
            "metadata": metadata or {},
            "plugins": []
        }
        
        for plugin in plugins:
            plugin_state = PluginState(
                id=plugin.id,
                class_name=plugin.__class__.__name__,
                params=plugin.get_params(),
                enabled=plugin.enabled,
                position=None  # TODO: UI position
            )
            preset["plugins"].append(plugin_state.to_dict())
        
        # Atomic write: write to temp file then rename
        preset_path = self.presets_dir / f"{name}.json"
        temp_path = preset_path.with_suffix(".json.tmp")
        
        with open(temp_path, 'w') as f:
            json.dump(preset, f, indent=2)
            f.flush()
            os.fsync(f.fileno())
        
        # Atomic rename
        shutil.move(str(temp_path), str(preset_path))
        
        # Backup previous version if exists
        if preset_path.exists():
            backup_path = self.backup_dir / f"{name}_{int(time.time())}.json"
            shutil.copy2(preset_path, backup_path)
        
        # Cloud sync
        if self.cloud_client:
            self.cloud_client.upload_preset(preset_path, preset)
        
        return preset_path
    
    def load_preset(self, name: str, plugins: List[EffectPlugin]) -> bool:
        """
        Apply preset to matching plugins.
        
        Args:
            name: Preset name
            plugins: List of plugin instances to configure
            
        Returns:
            True if successful, False if preset not found
        """
        preset_path = self.presets_dir / f"{name}.json"
        
        if not preset_path.exists():
            logger.error(f"Preset not found: {name}")
            return False
        
        try:
            with open(preset_path) as f:
                preset_data = json.load(f)
            
            # Validate schema version
            preset_version = preset_data.get("schema_version", "1.0.0")
            if preset_version != self.schema_version:
                logger.warning(f"Preset version mismatch: {preset_version} vs {self.schema_version}")
                preset_data = migrate_preset(preset_data, self.schema_version)
            
            # Build plugin lookup
            plugin_map = {p.id: p for p in plugins}
            
            # Apply params to matching plugins
            for plugin_state_data in preset_data["plugins"]:
                plugin_state = PluginState.from_dict(plugin_state_data)
                
                if plugin_state.id in plugin_map:
                    plugin = plugin_map[plugin_state.id]
                    plugin.set_params(plugin_state.params)
                    plugin.enabled = plugin_state.enabled
                    logger.debug(f"Applied preset to plugin {plugin_state.id}")
                else:
                    logger.warning(f"Plugin {plugin_state.id} not found in current project")
            
            logger.info(f"Preset '{name}' loaded successfully")
            return True
            
        except json.JSONDecodeError as e:
            logger.error(f"Failed to parse preset {name}: {e}")
            return False
        except Exception as e:
            logger.error(f"Failed to load preset {name}: {e}")
            return False
    
    def list_presets(self) -> List[Dict[str, Any]]:
        """List all available presets with metadata."""
        presets = []
        
        for preset_path in self.presets_dir.glob("*.json"):
            try:
                with open(preset_path) as f:
                    data = json.load(f)
                
                presets.append({
                    "name": data["name"],
                    "created_at": data["created_at"],
                    "metadata": data.get("metadata", {}),
                    "plugin_count": len(data.get("plugins", [])),
                    "file_size": preset_path.stat().st_size
                })
            except Exception as e:
                logger.warning(f"Failed to read preset {preset_path}: {e}")
        
        return sorted(presets, key=lambda x: x["created_at"], reverse=True)
    
    def delete_preset(self, name: str) -> bool:
        """Delete a preset."""
        preset_path = self.presets_dir / f"{name}.json"
        
        if not preset_path.exists():
            return False
        
        # Move to backup before deleting
        backup_path = self.backup_dir / f"{name}_deleted_{int(time.time())}.json"
        shutil.move(str(preset_path), str(backup_path))
        
        logger.info(f"Preset '{name}' deleted (backed up)")
        return True
    
    def save_project(self, name: str, plugins: List[EffectPlugin],
                    metadata: Optional[Dict] = None) -> Path:
        """
        Save complete project state.
        
        Similar to preset but includes all project-level settings.
        """
        project = Project(
            name=name,
            version=self.schema_version,
            plugins=[],
            metadata=metadata or {},
            created_at=time.time(),
            modified_at=time.time()
        )
        
        for plugin in plugins:
            plugin_state = PluginState(
                id=plugin.id,
                class_name=plugin.__class__.__name__,
                params=plugin.get_params(),
                enabled=plugin.enabled
            )
            project.plugins.append(plugin_state)
        
        # Atomic write
        project_path = self.projects_dir / f"{name}.vj3"
        temp_path = project_path.with_suffix(".vj3.tmp")
        
        with open(temp_path, 'w') as f:
            json.dump(project.to_dict(), f, indent=2)
            f.flush()
            os.fsync(f.fileno())
        
        shutil.move(str(temp_path), str(project_path))
        
        # Cloud sync
        if self.cloud_client:
            self.cloud_client.upload_project(project_path, project)
        
        return project_path
    
    def load_project(self, name: str, plugins: List[EffectPlugin]) -> bool:
        """Load complete project state."""
        project_path = self.projects_dir / f"{name}.vj3"
        
        if not project_path.exists():
            logger.error(f"Project not found: {name}")
            return False
        
        try:
            with open(project_path) as f:
                project_data = json.load(f)
            
            project = Project.from_dict(project_data)
            
            # Apply plugin states
            plugin_map = {p.id: p for p in plugins}
            
            for plugin_state in project.plugins:
                if plugin_state.id in plugin_map:
                    plugin = plugin_map[plugin_state.id]
                    plugin.set_params(plugin_state.params)
                    plugin.enabled = plugin_state.enabled
            
            logger.info(f"Project '{name}' loaded successfully")
            return True
            
        except Exception as e:
            logger.error(f"Failed to load project {name}: {e}")
            return False
    
    def list_projects(self) -> List[Dict[str, Any]]:
        """List all available projects."""
        projects = []
        
        for project_path in self.projects_dir.glob("*.vj3"):
            try:
                with open(project_path) as f:
                    data = json.load(f)
                
                projects.append({
                    "name": data["name"],
                    "version": data.get("version", "1.0.0"),
                    "created_at": data.get("created_at", 0),
                    "modified_at": data.get("modified_at", 0),
                    "plugin_count": len(data.get("plugins", [])),
                    "file_size": project_path.stat().st_size
                })
            except Exception as e:
                logger.warning(f"Failed to read project {project_path}: {e}")
        
        return sorted(projects, key=lambda x: x["modified_at"], reverse=True)
```

### 3.2 Cloud Sync (Optional)

**Purpose**: Sync presets across devices via cloud storage.

```python
class CloudSyncClient:
    """Abstract cloud sync client."""
    
    def __init__(self, provider: str, credentials: Dict):
        self.provider = provider
        if provider == "dropbox":
            self.client = DropboxClient(credentials)
        elif provider == "google_drive":
            self.client = GoogleDriveClient(credentials)
        elif provider == "s3":
            self.client = S3Client(credentials)
        else:
            raise ValueError(f"Unknown provider: {provider}")
    
    def upload_preset(self, local_path: Path, preset_data: Dict):
        """Upload preset to cloud."""
        remote_path = f"/vjlive3/presets/{local_path.name}"
        self.client.upload(local_path, remote_path)
    
    def download_preset(self, name: str) -> Dict:
        """Download preset from cloud."""
        remote_path = f"/vjlive3/presets/{name}.json"
        return self.client.download(remote_path)
    
    def list_remote_presets(self) -> List[Dict]:
        """List presets available in cloud."""
        return self.client.list("/vjlive3/presets/")
```

