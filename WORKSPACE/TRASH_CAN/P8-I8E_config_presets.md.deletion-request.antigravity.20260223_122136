def validate_preset(preset_data: Dict) -> List[str]:
    """Validate preset schema. Returns list of errors."""
    errors = []
    
    required_fields = ["schema_version", "name", "plugins"]
    for field in required_fields:
        if field not in preset_data:
            errors.append(f"Missing required field: {field}")
    
    if "plugins" in preset_data:
        for i, plugin_data in enumerate(preset_data["plugins"]):
            if "id" not in plugin_data:
                errors.append(f"Plugin {i}: missing 'id'")
            if "params" not in plugin_data:
                errors.append(f"Plugin {i}: missing 'params'")
    
    return errors
