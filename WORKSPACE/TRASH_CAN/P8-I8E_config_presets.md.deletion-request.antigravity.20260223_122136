# src/vjlive3/app.py
class VJLiveApp:
    def __init__(self, project_root: Path):
        self.project_root = project_root
        self.config_manager = ConfigManager(project_root)
        
        # Load cloud sync config
        cloud_config = self.load_config("config/cloud.yaml")
        if cloud_config.get("enabled", False):
            self.config_manager.cloud_client = CloudSyncClient(
                cloud_config["provider"],
                cloud_config["credentials"]
            )
        
        # Load default preset if specified
        default_preset = self.load_config("config/defaults.yaml").get("preset")
        if default_preset:
            self.config_manager.load_preset(default_preset, self.plugins)
    
    def save_preset(self, name: str):
        """Save current state as preset."""
        path = self.config_manager.save_preset(name, self.plugins)
        logger.info(f"Preset saved to {path}")
        
        # Notify UI
        self.ui.preset_saved(name)
    
    def load_preset(self, name: str):
        """Load preset by name."""
        success = self.config_manager.load_preset(name, self.plugins)
        if success:
            self.ui.preset_loaded(name)
        else:
            self.ui.show_error(f"Failed to load preset: {name}")
    
    def save_project(self, name: str):
        """Save complete project."""
        path = self.config_manager.save_project(name, self.plugins)
        logger.info(f"Project saved to {path}")
        self.ui.project_saved(name)
    
    def load_project(self, name: str):
        """Load complete project."""
        success = self.config_manager.load_project(name, self.plugins)
        if success:
            self.ui.project_loaded(name)
        else:
            self.ui.show_error(f"Failed to load project: {name}")
