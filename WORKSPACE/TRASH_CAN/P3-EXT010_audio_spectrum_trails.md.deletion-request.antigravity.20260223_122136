## 4. GLSL Fragment Shader (61 lines)

```glsl
#version 330 core
uniform vec2 resolution;
uniform float time;
uniform float u_mix;
uniform sampler2D tex0;

uniform float trail_decay;        // 0.8-0.99 (mapped from 0-10)
uniform float spectrum_height;    // 0.1-1.0 (mapped from 0-10)
uniform int frequency_bands;      // 16-256 (mapped from 0-10)
uniform int color_mode;           // 0, 1, or 2 (mapped from 0-10)
uniform float trail_opacity;      // 0.1-1.0 (mapped from 0-10)

uniform sampler2D spectrum_tex;   // 1D texture with spectrum data
uniform int spectrum_size;        // Length of spectrum array (e.g., 512)
uniform float bass_level;         // Normalized bass (0.0-1.0)
uniform float volume_level;       // Normalized volume (0.0-1.0)

out vec4 fragColor;
in vec2 uv;

vec3 get_spectrum_color(float freq, float intensity) {
    if (color_mode == 0) {
        // Rainbow: RGB sine waves with phase offsets
        return vec3(sin(freq*3.0)*0.5+0.5,
                   sin(freq*3.0+2.09)*0.5+0.5,
                   sin(freq*3.0+4.18)*0.5+0.5) * intensity;
    } else if (color_mode == 1) {
        // Grayscale
        return vec3(intensity);
    } else {
        // Blue-Orange: freq → (blue, orange, intensity)
        return vec3(freq, 1.0 - freq, intensity * 0.5);
    }
}

void main() {
    vec4 original = texture(tex0, uv);
    vec3 color = original.rgb;

    // Only draw in spectrum region (bottom of screen)
    if (uv.y < spectrum_height) {
        // Map UV x to frequency band index
        float band_pos = uv.x * float(frequency_bands);
        int band_idx = int(band_pos);

        // Sample spectrum from 1D texture
        float spectrum_value = 0.0;
        if (spectrum_size > 0 && band_idx < frequency_bands) {
            float spectrum_pos = float(band_idx) / float(frequency_bands) * float(spectrum_size);
            int spec_idx = int(spectrum_pos);
            if (spec_idx < spectrum_size) {
                spectrum_value = texelFetch(spectrum_tex, ivec2(spec_idx, 0), 0).r;
            }
        }

        // Apply volume scaling
        spectrum_value *= volume_level * 2.0;

        // Calculate bar height in UV space
        float trail_height = spectrum_value * spectrum_height;

        // Fill bar with spectrum color if within bar height
        if (uv.y < trail_height) {
            float freq = float(band_idx) / float(frequency_bands);
            vec3 spectrum_color = get_spectrum_color(freq, 1.0);
            color = mix(color, spectrum_color, trail_opacity * u_mix);
        }

        // Bass glow: additive glow from bass level
        float bass_glow = bass_level * 0.3 * (1.0 - uv.y / spectrum_height);
        color += vec3(bass_glow, bass_glow * 0.5, bass_glow * 0.2) * u_mix;
    }

    fragColor = vec4(color, original.a);
}
```

