def test_simple_chain():
    """A → B → C should schedule in order."""
    plugins = [
        PluginA(id="A", needs=[], provides=["depth"]),
        PluginB(id="B", needs=["depth"], provides=["audio"]),
        PluginC(id="C", needs=["audio"], provides=[]),
    ]
    
    scheduler = PluginScheduler()
    batches = scheduler.schedule(plugins)
    
    assert len(batches) == 3  # Sequential, no parallelism
    assert batches[0] == [plugins[0]]
    assert batches[1] == [plugins[1]]
    assert batches[2] == [plugins[2]]

def test_parallel_execution():
    """A,B → C should schedule A,B in same batch."""
    plugins = [
        PluginA(id="A", needs=[], provides=["depth"]),
        PluginB(id="B", needs=[], provides=["audio"]),
        PluginC(id="C", needs=["depth", "audio"], provides=[]),
    ]
    
    scheduler = PluginScheduler()
    batches = scheduler.schedule(plugins)
    
    assert len(batches) == 2
    assert set(batches[0]) == {plugins[0], plugins[1]}  # Parallel
    assert batches[1] == [plugins[2]]

def test_cycle_detection():
    """A → B → A should raise error."""
    plugins = [
        PluginA(id="A", needs=["output"], provides=["intermediate"]),
        PluginB(id="B", needs=["intermediate"], provides=["output"]),
    ]
    
    scheduler = PluginScheduler()
    with pytest.raises(ValueError, match="Cyclic dependency"):
        scheduler.schedule(plugins)
```

