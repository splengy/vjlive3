def test_error_count_reset():
    """Successful execution should reduce error count."""
    plugin = FailingPlugin(fail_times=1)
    wrapper = SafePluginWrapper(plugin, error_threshold=5)
    
    # First call fails
    with pytest.raises(PluginError):
        wrapper.process(...)
    assert wrapper.error_count == 1
    
    # Second call succeeds (plugin fixed)
    plugin.fail_times = 0
    result = wrapper.process(...)
    assert wrapper.error_count == 0  # Reset

def test_temporary_disable():
    """After threshold errors, plugin disabled for cooldown."""
    plugin = AlwaysFailingPlugin()
    wrapper = SafePluginWrapper(plugin, error_threshold=3)
    context = VJLiveContext()
    
    # Fail 3 times
    for _ in range(3):
        try:
            wrapper.process(...)
        except:
            pass
    
    assert wrapper.disabled_until > context.time
    # Next call should not execute plugin
    result = wrapper.process(...)
    assert result == wrapper.get_disabled_output(...)
