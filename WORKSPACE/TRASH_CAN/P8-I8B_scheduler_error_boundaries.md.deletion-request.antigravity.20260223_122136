### 3.2 DAG Scheduler

**Purpose**: Topologically sort plugins by dependencies and group into parallel batches.

```python
from typing import Dict, Set, List, Tuple
from collections import defaultdict, deque

class PluginScheduler:
    """Schedule plugins based on input-output dependencies."""
    
    def __init__(self):
        self.graph: Dict[str, Set[str]] = defaultdict(set)  # plugin_id -> {deps}
        self.reverse_graph: Dict[str, Set[str]] = defaultdict(set)  # dep -> {plugins}
    
    def build_dependency_graph(self, plugins: List[EffectPlugin]) -> Dict[str, Set[str]]:
        """Build complete dependency graph from plugin declarations."""
        graph = {}
        
        for plugin in plugins:
            # Map plugin ID to its dependencies
            deps = plugin.required_inputs
            
            # Also include implicit dependencies from previous plugins in chain
            # (for backward compatibility with linear chains)
            if hasattr(plugin, 'chain_position'):
                # Plugins earlier in chain are implicit dependencies
                pass
            
            graph[plugin.id] = deps
            
            # Build reverse graph for topological sort
            for dep in deps:
                self.reverse_graph[dep].add(plugin.id)
        
        return graph
    
    def topological_sort(self, graph: Dict[str, Set[str]]) -> List[str]:
        """Kahn's algorithm for topological sorting."""
        # Compute in-degree for each node
        in_degree = defaultdict(int)
        for node, deps in graph.items():
            in_degree[node] = len(deps)
            for dep in deps:
                if dep not in in_degree:
                    in_degree[dep] = 0
        
        # Start with nodes that have no dependencies
        queue = deque([node for node, deg in in_degree.items() if deg == 0])
        sorted_nodes = []
        
        while queue:
            node = queue.popleft()
            sorted_nodes.append(node)
            
            # Reduce in-degree of dependents
            for dependent in self.reverse_graph.get(node, []):
                in_degree[dependent] -= 1
                if in_degree[dependent] == 0:
                    queue.append(dependent)
        
        # Check for cycles
        if len(sorted_nodes) != len(in_degree):
            cycle_nodes = set(in_degree.keys()) - set(sorted_nodes)
            raise ValueError(f"Cyclic dependency detected: {cycle_nodes}")
        
        return sorted_nodes
    
    def schedule_parallel_batches(self, sorted_nodes: List[str], 
                                 graph: Dict[str, Set[str]]) -> List[List[str]]:
        """Group plugins into batches that can run in parallel."""
        batches = []
        current_batch = []
        provided_outputs = set()  # What's available after current batch
        
        for plugin_id in sorted_nodes:
            deps = graph[plugin_id]
            
            # Check if all dependencies are satisfied by previous batches
            if deps.issubset(provided_outputs):
                # Can run in current batch
                current_batch.append(plugin_id)
            else:
                # Need to start new batch
                if current_batch:
                    batches.append(current_batch)
                current_batch = [plugin_id]
            
            # Add this plugin's outputs to available set
            plugin = self.get_plugin_by_id(plugin_id)
            provided_outputs.update(plugin.provides)
        
        if current_batch:
            batches.append(current_batch)
        
        return batches
    
    def schedule(self, plugins: List[EffectPlugin]) -> List[List[EffectPlugin]]:
        """Full scheduling pipeline: build graph, sort, batch."""
        # Build dependency graph
        graph = self.build_dependency_graph(plugins)
        
        # Topological sort
        sorted_ids = self.topological_sort(graph)
        
        # Group into parallel batches
        batch_ids = self.schedule_parallel_batches(sorted_ids, graph)
        
        # Convert IDs back to plugin objects
        plugin_map = {p.id: p for p in plugins}
        batches = [[plugin_map[pid] for pid in batch] for batch in batch_ids]
        
        return batches
```

### 3.3 Safe Plugin Wrapper

**Purpose**: Catch plugin exceptions and provide graceful degradation.

```python
import traceback
import logging
from typing import Optional

logger = logging.getLogger(__name__)

class SafePluginWrapper:
    """Wrapper that catches exceptions and provides fallback behavior."""
    
    def __init__(self, plugin: EffectPlugin, 
                 error_threshold: int = 5,
                 fallback_mode: str = "passthrough"):
        self.plugin = plugin
        self.error_threshold = error_threshold
        self.fallback_mode = fallback_mode
        
        self.error_count = 0
        self.last_error: Optional[Exception] = None
        self.disabled_until: float = 0.0  # Timestamp when plugin can be re-enabled
        
        # Create fallback texture (1x1 transparent pixel)
        self.fallback_texture = self.create_placeholder_texture()
    
    def create_placeholder_texture(self) -> Texture:
        """Create a 1x1 transparent texture as fallback."""
        texture = Texture(1, 1)
        texture.data[:] = [0, 0, 0, 0]  # RGBA = transparent black
        return texture
    
    def process(self, input_texture: Texture, params: Dict, 
                context: VJLiveContext) -> Texture:
        """Execute plugin with error handling."""
        
        # Check if plugin is temporarily disabled
        if context.time < self.disabled_until:
            logger.warning(f"Plugin {self.plugin.id} temporarily disabled")
            return self.get_disabled_output(input_texture, context)
        
        try:
            # Execute plugin
            output = self.plugin.process(input_texture, params, context)
            
            # Success: reset error count gradually
            self.error_count = max(0, self.error_count - 1)
            
            return output
            
        except Exception as e:
            self.error_count += 1
            self.last_error = e
            
            # Log error with full traceback
            logger.error(
                f"Plugin {self.plugin.id} failed (error {self.error_count}/{self.error_threshold}): {e}\n"
                f"{traceback.format_exc()}"
            )
            
            # Increment global safety violation counter
            context.safety_violations += 1
            
            # Check if we should disable plugin temporarily
            if self.error_count >= self.error_threshold:
                self.disabled_until = context.time + 10.0  # Disable for 10 seconds
                logger.error(f"Plugin {self.plugin.id} disabled for 10 seconds")
            
            # Return appropriate fallback
            return self.get_fallback_output(input_texture, context, e)
    
    def get_fallback_output(self, input_texture: Texture, 
                           context: VJLiveContext, 
                           error: Exception) -> Texture:
        """Determine fallback behavior based on mode."""
        if self.fallback_mode == "passthrough":
            # Simply pass input through
            return input_texture
        
        elif self.fallback_mode == "placeholder":
            # Return solid color or placeholder texture
            return self.fallback_texture
        
        elif self.fallback_mode == "last_good":
            # Return last successful output (would need caching)
            # Not implemented in first version
            return input_texture
        
        else:
            logger.warning(f"Unknown fallback mode: {self.fallback_mode}")
            return input_texture
    
    def get_disabled_output(self, input_texture: Texture, 
                           context: VJLiveContext) -> Texture:
        """Output when plugin is temporarily disabled."""
        # Could show error message in corner of screen
        # For now, simple passthrough
        return input_texture
    
    def reset(self):
        """Reset error state (call when plugin parameters change)."""
        self.error_count = 0
        self.last_error = None
        self.disabled_until = 0.0
    
    @property
    def is_healthy(self) -> bool:
        """Check if plugin is functioning normally."""
        return self.error_count == 0 and context.time < self.disabled_until
```

### 3.4 Integration with Engine

**New Engine Loop:**

```python
class RenderEngine:
    def __init__(self):
        self.context = VJLiveContext()
        self.scheduler = PluginScheduler()
        self.wrapped_plugins: List[SafePluginWrapper] = []
        
        # Wrap all plugins with error boundaries
        for plugin in self.active_plugins:
            wrapper = SafePluginWrapper(plugin, error_threshold=5)
            self.wrapped_plugins.append(wrapper)
        
        # Pre-compute schedule (static for fixed plugin set)
        self.schedule = self.scheduler.schedule(self.wrapped_plugins)
    
    def render_frame(self):
        """Main render loop with scheduling and error boundaries."""
        self.update_context()
        
        # Execute plugins in batches
        input_texture = self.context.video
        
        for batch in self.schedule:
            # Execute all plugins in this batch (potentially in parallel)
            batch_outputs = self.execute_batch(batch, input_texture)
            
            # For now, chain outputs sequentially within batch
            # Future: use threading pool for true parallelism
            if batch_outputs:
                input_texture = batch_outputs[-1]  # Last plugin's output
        
        # Display final output
        self.display(input_texture)
        
        # Update telemetry
        self.telemetry.collect_frame_metrics()
    
    def execute_batch(self, batch: List[SafePluginWrapper], 
                     input_texture: Texture) -> List[Texture]:
        """Execute all plugins in a batch."""
        outputs = []
        current_input = input_texture
        
        for wrapper in batch:
            params = wrapper.plugin.get_params()
            output = wrapper.process(current_input, params, self.context)
            outputs.append(output)
            current_input = output
        
        return outputs
```

