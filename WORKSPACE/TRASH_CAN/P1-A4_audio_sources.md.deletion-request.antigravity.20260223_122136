## Public Interface

### AudioSourceManager Class

```python
# src/vjlive3/audio/sources.py
class AudioSourceManager:
    def __init__(self):
        """Initialize audio source manager"""
    
    def enumerate_devices(self) -> List[AudioDeviceInfo]:
        """Get list of available audio input devices"""
    
    def get_default_device(self) -> Optional[AudioDeviceInfo]:
        """Get default audio input device"""
    
    def set_active_device(self, device_id: str) -> None:
        """Set active audio input device"""
    
    def get_active_device(self) -> Optional[AudioDeviceInfo]:
        """Get currently active audio input device"""
    
    def add_audio_analyzer(self, analyzer: AudioAnalyzer, device_id: Optional[str] = None) -> None:
        """Add audio analyzer to specific device"""
    
    def remove_audio_analyzer(self, analyzer: AudioAnalyzer) -> None:
        """Remove audio analyzer from device"""
    
    def get_device_status(self, device_id: str) -> DeviceStatus:
        """Get status of audio device"""
    
    def save_device_profile(self, profile_name: str) -> None:
        """Save current device configuration"""
    
    def load_device_profile(self, profile_name: str) -> None:
        """Load device configuration"""
```

### AudioDeviceInfo Data Structure

```python
@dataclass
class AudioDeviceInfo:
    id: str                    # Unique device identifier
    name: str                  # Human-readable name
    channels: int              # Number of input channels
    sample_rates: List[int]    # Supported sample rates
    default_sample_rate: int   # Default sample rate
    is_default: bool           # Is this the system default?
    is_active: bool            # Is this device currently active?
    latency: float             # Round-trip latency in ms
```

